      "source": "JR東日本",
      "translation": "JR East"
    },
    {
      "key": "contribution.{57644AE6-7FFA-E351-8FE0-7567171D3CEF}.type",
      "source": "E351系",
      "translation": "E351 Series"
    },
    {
      "key": "contribution.{57644AE6-7FFA-E351-8FE0-7567171D3CEF}.description",
      "source": "中央東線のスーパーあずさ。12両まで編成可能。",
      "translation": "Super Azusa on the Chuo East Line. Can be formed into up to 12 cars."
    },
    {
      "key": "contribution.{57644AE6-7FFA-H731-8FE0-7567171D3CEF}.company",
      "source": "JR北海道",
      "translation": "JR Hokkaido"
    },
    {
      "key": "contribution.{57644AE6-7FFA-H731-8FE0-7567171D3CEF}.type",
