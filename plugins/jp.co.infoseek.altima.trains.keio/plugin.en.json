{
  "language": "en",
  "plugin": "jp.co.infoseek.altima.trains.keio",
  "sourceManifest": "plugin.xml",
  "texts": [
    {
      "key": "plugin.title",
      "source": "京王電鉄車両プラグイン",
      "translation": ""
    },
    {
      "key": "contribution.{C8A90EE2-2C5E-4F1E-ALTM-KEO10A006000}.name",
      "source": "京王線,相模原線など",
      "translation": ""
    },
    {
      "key": "contribution.{C8A90EE2-2C5E-4F1E-ALTM-KEO10A006000}.company",
      "source": "京王電鉄",
      "translation": ""
    },
    {
      "key": "contribution.{C8A90EE2-2C5E-4F1E-ALTM-KEO10A006000}.type",
      "source": "6000系",
      "translation": ""
    },
    {
      "key": "contribution.{C8A90EE2-2C5E-4F1E-ALTM-KEO10A006000}.description",
      "source": "京王電鉄初の20ｍ車として1972年に登場。ワンハンドルマスコンの採用や都営新宿線直通を考慮した設計で、1次車は抵抗制御、2次車以降は界磁チョッパを採用している。5扉車や都営線乗り入れ車などもあり、最大304両の大所帯だったが、9000系と入れ替わるように徐々に廃車が進んでいる。",
      "translation": ""
    },
    {
      "key": "contribution.{C8A90EE2-2C5E-4F1E-ALTM-KEO14A006000}.name",
      "source": "京王線など",
      "translation": ""
    },
    {
      "key": "contribution.{C8A90EE2-2C5E-4F1E-ALTM-KEO14A006000}.company",
      "source": "京王電鉄",
      "translation": ""
    },
    {
      "key": "contribution.{C8A90EE2-2C5E-4F1E-ALTM-KEO14A006000}.type",
      "source": "6000系(新塗装)",
      "translation": ""
    },
    {
      "key": "contribution.{C8A90EE2-2C5E-4F1E-ALTM-KEO14A006000}.description",
      "source": "2002年度中に全車が従来のエンジ帯から赤青2色帯に変更された。再塗装されたものとシールを貼り付けたものの2種類がある。",
      "translation": ""
    },
    {
      "key": "contribution.{C8A90EE2-2C5E-4F1E-ALTM-KEO10B007000}.name",
      "source": "京王線,相模原線など",
      "translation": ""
    },
    {
      "key": "contribution.{C8A90EE2-2C5E-4F1E-ALTM-KEO10B007000}.company",
      "source": "京王電鉄",
      "translation": ""
    },
    {
      "key": "contribution.{C8A90EE2-2C5E-4F1E-ALTM-KEO10B007000}.type",
      "source": "7000系",
      "translation": ""
    },
    {
      "key": "contribution.{C8A90EE2-2C5E-4F1E-ALTM-KEO10B007000}.description",
      "source": "1984年に登場。足回りなど基本的に6000系と同じ界磁チョッパで、ステンレス車体を採用して軽量化した。無塗装の銀色前面だったが、視認性向上のためアイボリーに塗られた。コルゲート車体からビートプレスに変更されスマートになった20番台(7020系)が後に登場。現在は2、4、6、8、10連が揃っている。",
      "translation": ""
    },
    {
      "key": "contribution.{C8A90EE2-2C5E-4F1E-ALTM-KEO14B007000}.name",
      "source": "京王線など",
      "translation": ""
    },
    {
      "key": "contribution.{C8A90EE2-2C5E-4F1E-ALTM-KEO14B007000}.company",
      "source": "京王電鉄",
      "translation": ""
    },
    {
      "key": "contribution.{C8A90EE2-2C5E-4F1E-ALTM-KEO14B007000}.type",
      "source": "7000系(新塗装)",
      "translation": ""
    },
    {
      "key": "contribution.{C8A90EE2-2C5E-4F1E-ALTM-KEO14B007000}.description",
      "source": "2001年から初期の車両を中心に内外装の更新工事を実施、従来のエンジ帯から赤青2色帯に変更された。追って未更新の車両にも同様の塗色変更が行なわれた。",
      "translation": ""
    },
    {
      "key": "contribution.{C8A90EE2-2C5E-4F1E-ALTM-KEO10C008000}.name",
      "source": "京王線,相模原線,高尾線",
      "translation": ""
    },
    {
      "key": "contribution.{C8A90EE2-2C5E-4F1E-ALTM-KEO10C008000}.company",
      "source": "京王電鉄",
      "translation": ""
    },
    {
      "key": "contribution.{C8A90EE2-2C5E-4F1E-ALTM-KEO10C008000}.type",
      "source": "8000系",
      "translation": ""
    },
    {
      "key": "contribution.{C8A90EE2-2C5E-4F1E-ALTM-KEO10C008000}.description",
      "source": "1992年に登場した京王初のGTO-VVVF車。新たなコーポレートカラーであるチェリーレッド、インディゴブルーの帯を巻き、90年代の京王のイメージリーダーとなった。6連＋4連、8連がある。都営新宿線内乗り入れには使われない。",
      "translation": ""
    },
    {
      "key": "contribution.{C8A90EE2-2C5E-4F1E-ALTM-KEO20C008000}.company",
      "source": "京王電鉄",
      "translation": ""
    },
    {
      "key": "contribution.{C8A90EE2-2C5E-4F1E-ALTM-KEO20C008000}.type",
      "source": "8000系(6連＋4連)",
      "translation": ""
    },
    {
      "key": "contribution.{C8A90EE2-2C5E-4F1E-ALTM-KEO20C008000}.description",
      "source": "6連＋4連の10両編成を再現。(10両編成のみ購入可能)",
      "translation": ""
    },
    {
      "key": "contribution.{C8A90EE2-2C5E-4F1E-ALTM-KEO10D009000}.name",
      "source": "京王線,相模原線,高尾線",
      "translation": ""
    },
    {
      "key": "contribution.{C8A90EE2-2C5E-4F1E-ALTM-KEO10D009000}.company",
      "source": "京王電鉄",
      "translation": ""
    },
    {
      "key": "contribution.{C8A90EE2-2C5E-4F1E-ALTM-KEO10D009000}.type",
      "source": "9000系",
      "translation": ""
    },
    {
      "key": "contribution.{C8A90EE2-2C5E-4F1E-ALTM-KEO10D009000}.description",
      "source": "2000年に登場した京王の最新鋭車両。IGBT-VVVFや片持ち式シートを採用、8000系に比べて特にバリアフリーを強化している。都営新宿線乗り入れにも対応するが、都合によりまだ運用されていない。8両編成のみのため、10連運用するときは6000系または7000系2連を増結する。",
      "translation": ""
    },
    {
      "key": "contribution.{C8A90EE2-2C5E-4F1E-ALTM-KEO20D009000}.company",
      "source": "京王電鉄",
      "translation": ""
    },
    {
      "key": "contribution.{C8A90EE2-2C5E-4F1E-ALTM-KEO20D009000}.type",
      "source": "9000系＋6000系",
      "translation": ""
    },
    {
      "key": "contribution.{C8A90EE2-2C5E-4F1E-ALTM-KEO20D009000}.description",
      "source": "「特急」など優等列車として運用される時は主に6000系2連を増結し10両編成となる。(10両編成のみ購入可能)",
      "translation": ""
    },
    {
      "key": "contribution.{C8A90EE2-2C5E-4F1E-ALTM-KEO30D009000}.company",
      "source": "京王電鉄",
      "translation": ""
    },
    {
      "key": "contribution.{C8A90EE2-2C5E-4F1E-ALTM-KEO30D009000}.type",
      "source": "9000系＋7000系",
      "translation": ""
    },
    {
      "key": "contribution.{C8A90EE2-2C5E-4F1E-ALTM-KEO30D009000}.description",
      "source": "ごく稀に7000系2連を増結することもある。(10両編成のみ購入可能)",
      "translation": ""
    }
  ]
}
