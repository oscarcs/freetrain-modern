  "texts": [
    {
      "key": "plugin.title",
      "source": "気動車セット",
      "translation": "Diesel Railcar Set"
    },
    {
      "key": "contribution.{CyberExpress1703d-kiha48kazekko}.name",
      "source": "基本編成",
      "translation": "Basic Formation"
    },
    {
      "key": "contribution.{CyberExpress1703d-kiha48kazekko}.company",
      "source": "JR東日本",
      "translation": "JR East"
    },
    {
      "key": "contribution.{CyberExpress1703d-kiha48kazekko}.type",
      "source": "キハ48形 びゅうコースター風っこ",
      "translation": "Kiha 48 View Coaster Kazekko"
    },
    {
      "key": "contribution.{CyberExpress1703d-kiha48kazekko}.description",
      "source": "※2両編成のみ※　キハ48を改造したトロッコ車両です。足元まで開いた大きな窓と、レトロ調の車内が特徴です。所属は仙台ですが、JR東日本の各線に出張して運行しています。",
      "translation": "*2-car formation only* This is a trolley car modified from a KiHa 48. It features large windows that open to the floor and a retro-style interior. Although based in Sendai, it operates on various JR East lines as a special service."
    },
    {
      "key": "contribution.{CyberExpress1703d-kiha48kazekko-kururi}.name",
      "source": "風っこくるり号",
      "translation": "Kazekko Kururi"
    },
    {
      "key": "contribution.{CyberExpress1703d-kiha48kazekko-kururi}.company",
      "source": "JR東日本",
      "translation": "JR East"
    },
    {
      "key": "contribution.{CyberExpress1703d-kiha48kazekko-kururi}.type",
      "source": "キハ48形 びゅうコースター風っこ",
      "translation": "Kiha 48 View Coaster Kazekko"
    },
    {
      "key": "contribution.{CyberExpress1703d-kiha48kazekko-kururi}.description",
      "source": "※4両編成のみ※　久留里線で運行する風っこは、先頭にキハ38系を連結します。",
      "translation": "*4-car formation only* The Kazekko operating on the Kururi Line couples with a KiHa 38 Series at the front."
    },
    {
      "key": "contribution.{CyberExpress1703d-kiha48kazekko-tadami}.name",
      "source": "風っこ会津只見号",
      "translation": "Kazekko Aizu Tadami"
    },
    {
      "key": "contribution.{CyberExpress1703d-kiha48kazekko-tadami}.company",
      "source": "JR東日本",
      "translation": "JR East"
    },
    {
      "key": "contribution.{CyberExpress1703d-kiha48kazekko-tadami}.type",
      "source": "キハ48形 びゅうコースター風っこ",
      "translation": "Kiha 48 View Coaster Kazekko"
    },
    {
      "key": "contribution.{CyberExpress1703d-kiha48kazekko-tadami}.description",
      "source": "※3両編成のみ※　新潟県の長岡から福島県の只見まで運行した風っこ号です。途中に六十里越トンネルがあるため、風除け用に一般車両を連結しました。",
      "translation": "*3-car formation only* This is the Kazekko train that operated from Nagaoka, Niigata Prefecture, to Tadami, Fukushima Prefecture. Due to the Rokujurigoe Tunnel along the route, a general-purpose car was coupled for wind protection."
    },
    {
      "key": "contribution.{CyberExpress1703d-kiha48kazekko-senzan}.name",
      "source": "風っこ仙山もみじ号",
      "translation": "Kazekko Senzan Momiji"
    },
    {
      "key": "contribution.{CyberExpress1703d-kiha48kazekko-senzan}.company",
      "source": "JR東日本",
      "translation": "JR East"
    },
    {
      "key": "contribution.{CyberExpress1703d-kiha48kazekko-senzan}.type",
      "source": "キハ48形 びゅうコースター風っこ",
      "translation": "Kiha 48 View Coaster Kazekko"
    },
    {
      "key": "contribution.{CyberExpress1703d-kiha48kazekko-senzan}.description",
      "source": "※2両編成のみ※　仙山線を運行した風っこ号です。途中に急勾配があるため、エンジンが強力な一般車両を連結しました。",
      "translation": "*2-car formation only* This is the Kazekko train that operated on the Senzan Line. Due to steep gradients along the route, a general-purpose car with a powerful engine was coupled."
    },
    {
      "key": "contribution.{CyberExpress1703d-kiha48kazekko-hanakairo}.name",
      "source": "風っこ花回廊号",
      "translation": "Kazekko Hanakairo"
    },
    {
      "key": "contribution.{CyberExpress1703d-kiha48kazekko-hanakairo}.company",
      "source": "JR東日本",
      "translation": "JR East"
    },
    {
      "key": "contribution.{CyberExpress1703d-kiha48kazekko-hanakairo}.type",
      "source": "キハ48形 びゅうコースター風っこ",
      "translation": "Kiha 48 View Coaster Kazekko"
    },
    {
      "key": "contribution.{CyberExpress1703d-kiha48kazekko-hanakairo}.description",
      "source": "※2両編成のみ※　山形鉄道フラワー長井線を運行した風っこ号です。途中に急勾配があるため、エンジンが強力な一般車両を連結しました。",
      "translation": "*2-car formation only* This is the Kazekko train that operated on the Yamagata Railway Flower Nagai Line. Due to steep gradients along the route, a general-purpose car with a powerful engine was coupled."
    },
    {
