{
  "language": "en",
  "plugin": "jp.big.TAKUROU.freetrain.trains3",
  "sourceManifest": "plugin.xml",
  "texts": [
    {
      "key": "contribution.{AD070310-7653-11D7-A4B7-DCH183-H}.name",
      "source": "HET183 北斗",
      "translation": ""
    },
    {
      "key": "contribution.{AD070310-7653-11D7-A4B7-DCH183-H}.company",
      "source": "JR北海道",
      "translation": ""
    },
    {
      "key": "contribution.{AD070310-7653-11D7-A4B7-DCH183-H}.type",
      "source": "キハ183系",
      "translation": ""
    },
    {
      "key": "contribution.{AD070310-7653-11D7-A4B7-DCH183-H}.description",
      "source": "「スーパー北斗」の登場に併せて、従来からの「北斗」も大幅なリニューアルが施されました。\n車輌そのものは130km/hの高速運転が可能なように機器類の改造が行われ、室内インテリアも「スーパー北斗」に準じたものになっています。\nグリーン車は２+１配列ハイデッカー車両を併結。",
      "translation": ""
    },
    {
      "key": "contribution.{AD070310-7653-11D7-A4B7-DCQ185-Q}.name",
      "source": "特急「あそ｣「ゆふ」",
      "translation": ""
    },
    {
      "key": "contribution.{AD070310-7653-11D7-A4B7-DCQ185-Q}.company",
      "source": "JR九州",
      "translation": ""
    },
    {
      "key": "contribution.{AD070310-7653-11D7-A4B7-DCQ185-Q}.type",
      "source": "キハ185系",
      "translation": ""
    },
    {
      "key": "contribution.{AD070310-7653-11D7-A4B7-DCQ185-Q}.description",
      "source": "国鉄末期に四国島内向けの新性能気動車として投入されたが、ＪＲ四国発足以後に後継の特急車が\n誕生した事で余剰となり、一方で自社内での急行格上げによる特急設定の為、気動車を必要としたＪＲ九州が四国から購入してコーポトレートカラーに\n塗り替えて投入した。当初あそ・ゆふともに独自の塗装をしていたが、車両の共通化により共用の塗装に変った。",
      "translation": ""
    },
    {
      "key": "contribution.{AD070310-7653-11D7-A4B7-DCS1000-S}.name",
      "source": "一般形気動車",
      "translation": ""
    },
    {
      "key": "contribution.{AD070310-7653-11D7-A4B7-DCS1000-S}.company",
      "source": "JR四国",
      "translation": ""
    },
    {
      "key": "contribution.{AD070310-7653-11D7-A4B7-DCS1000-S}.type",
      "source": "1000形",
      "translation": ""
    },
    {
      "key": "contribution.{AD070310-7653-11D7-A4B7-DCS1000-S}.description",
      "source": "車内は7000形電車と同様の、車両の片側がロングシート、反対側がクロスシートとなっている「千鳥配置」。\n車両の中央部に両開きの扉があるが、ワンマン運転の時には締め切り、前後の片開き扉からの乗り降りとなる。\n軽快タイプの３扉大型車で400PSエンジンを搭載。徳島・高知方面で活躍。",
      "translation": ""
    },
    {
      "key": "contribution.{AD070310-7653-11D7-A4B7-ECW221}.name",
      "source": "汎用形近郊電車",
      "translation": ""
    },
    {
      "key": "contribution.{AD070310-7653-11D7-A4B7-ECW221}.company",
      "source": "JR西日本",
      "translation": ""
    },
    {
      "key": "contribution.{AD070310-7653-11D7-A4B7-ECW221}.type",
      "source": "221系",
      "translation": ""
    },
    {
      "key": "contribution.{AD070310-7653-11D7-A4B7-ECW221}.description",
      "source": "新快速用117系の置換え、及び老朽化した113系の置換え用として製造された。\n制御方式は211系に準じた添加励磁制御で、2両、4両、6両、8両のどの編成でもMT比を1:1とするためユニット方式車と1M車がある。\n車体は鋼製で３扉転換クロスシートである。\n投入当初は東海道・山陽線新快速、関西線に投入されたが、新快速の130km/h化に伴い新快速からは撤退し、東海道・山陽快速、関西線、奈良線、福知山線など近畿圏で広く使われている。",
      "translation": ""
    },
    {
      "key": "contribution.{AD070310-7653-11D7-A4B7-ECC313}.name",
      "source": "汎用形近郊電車",
      "translation": ""
    },
    {
      "key": "contribution.{AD070310-7653-11D7-A4B7-ECC313}.company",
      "source": "JR東海",
      "translation": ""
    },
    {
      "key": "contribution.{AD070310-7653-11D7-A4B7-ECC313}.type",
      "source": "313系",
      "translation": ""
    },
    {
      "key": "contribution.{AD070310-7653-11D7-A4B7-ECC313}.description",
      "source": "1999年から合計187両が製造されたＪＲ東海の次世代一般型車両です。\n通勤形からローカル形まで外観など共通化を図っています。\nVVVFインバータ制御による185kW大出力モーターで最高運転速度は120km/h（130km/h対応工事準備）、起動加速度2.6km/h/sという高性能を誇ります。\n車椅子対応座席や車椅子対応トイレなどのバリアフリー設計は共通しています。\nまた一方で古タイヤリサイクル床材やポリウレタン座席など低コスト化や低騒音化も図っています。\nドア開閉チャイムや電光表示もあります。2両編成、3両編成、4両編成とバラエティーに富んだ編成になっている。",
      "translation": ""
    },
    {
      "key": "contribution.{AD070310-7653-11D7-A4B7-ECW223_2000}.name",
      "source": "2000番台近郊電車",
      "translation": ""
    },
    {
      "key": "contribution.{AD070310-7653-11D7-A4B7-ECW223_2000}.company",
      "source": "JR西日本",
      "translation": ""
    },
    {
      "key": "contribution.{AD070310-7653-11D7-A4B7-ECW223_2000}.type",
      "source": "223系",
      "translation": ""
    },
    {
      "key": "contribution.{AD070310-7653-11D7-A4B7-ECW223_2000}.description",
      "source": "阪神大震災後のＪＲの早期復興で他鉄道からの旅客の流入による乗客増に備えて新快速などが増発される事となり、223系1000番台が新製された。\n続いて増備された2000･3000番台では、さらにコストを抑え、必要最小限の機器構成となっている。 \nまた，座席の簡素化および日除けカーテンの廃止なども実施されている。\n新快速の高速化により130km/ｈ対応可能の性能になった。",
      "translation": ""
    },
    {
      "key": "contribution.{AD070310-7653-11D7-A4B7-DCE110_300A}.name",
      "source": "300番台秋田ﾘﾚｰ号",
      "translation": ""
    },
    {
      "key": "contribution.{AD070310-7653-11D7-A4B7-DCE110_300A}.company",
      "source": "JR東日本",
      "translation": ""
    },
    {
      "key": "contribution.{AD070310-7653-11D7-A4B7-DCE110_300A}.type",
      "source": "キハ111･112系",
      "translation": ""
    },
    {
      "key": "contribution.{AD070310-7653-11D7-A4B7-DCE110_300A}.description",
      "source": "特急秋田リレー号は新鋭キハ110型気動車を使用した列車で、特急たざわ号のピンチヒッターとして北上線経由で秋田駅から東北新幹線の北上駅までを結んでいた。\n役目を終えたリレー号の気動車であるが廃車されるようなことはなく、車体は飯山線に、内装の転換クロスシートは東海道線の２階建てグリーン車などへの転用された。",
      "translation": ""
    },
    {
      "key": "contribution.{AD070310-7653-11D7-A4B7-ECC373-C}.name",
      "source": "ワイドビュー特急電車",
      "translation": ""
    },
    {
      "key": "contribution.{AD070310-7653-11D7-A4B7-ECC373-C}.company",
      "source": "JR東海",
      "translation": ""
    },
    {
      "key": "contribution.{AD070310-7653-11D7-A4B7-ECC373-C}.type",
      "source": "373系",
      "translation": ""
    },
    {
      "key": "contribution.{AD070310-7653-11D7-A4B7-ECC373-C}.description",
      "source": "急行東海・富士川の特急化に際して新造された直流用特急車輌。\n普通列車に転用できるようにドアは両開き・大型となっていて、デッキと客室を区切る扉はない。\nまた車体は軽量ステンレス製とし、動力車を３両中１両としていることも特徴として挙げられる。\n現在は特急「東海」「富士川」「伊那路」の他、東京ー大垣間を結ぶ夜行快速「ムーンライトながら」、さらには間合い運用で「セントラルライナー」にも投入されている。",
      "translation": ""
    },
    {
      "key": "contribution.{AD070310-7653-11D7-A4B7-DCE110-E}.name",
      "source": "汎用型気動車",
      "translation": ""
    },
    {
      "key": "contribution.{AD070310-7653-11D7-A4B7-DCE110-E}.company",
      "source": "JR東日本",
      "translation": ""
    },
    {
      "key": "contribution.{AD070310-7653-11D7-A4B7-DCE110-E}.type",
      "source": "キハ110系",
      "translation": ""
    },
    {
      "key": "contribution.{AD070310-7653-11D7-A4B7-DCE110-E}.description",
      "source": "ローカル線のサービス改善を図るため、ＪＲ東日本が開発した気動車。\n車体の長さ、両運転台または片運転台などで多彩な車両があり、路線条件に応じて使われている。\n1両または、2両編成となっていて、これらを組み合わせて、3～6両で運転できる様になっている。\nキハ100、110系は電車並みの加速性能を持っているため、ローカル線のスピードアップに大きく寄与したほか、釜石線で走行している車両はリクライニングシート、飯山線の車両は展望式の座席配置となっているなど、様々なバリエーションがある。",
      "translation": ""
    },
    {
      "key": "contribution.{AD070310-7653-11D7-A4B7-DCE110_200E}.name",
      "source": "汎用型気動車",
      "translation": ""
    },
    {
      "key": "contribution.{AD070310-7653-11D7-A4B7-DCE110_200E}.company",
      "source": "JR東日本",
      "translation": ""
    },
    {
      "key": "contribution.{AD070310-7653-11D7-A4B7-DCE110_200E}.type",
      "source": "キハ111･112系",
      "translation": ""
    },
    {
      "key": "contribution.{AD070310-7653-11D7-A4B7-DCE110_200E}.description",
      "source": "ローカル線のサービス改善を図るため、ＪＲ東日本が開発した気動車。\n車体の長さ、両運転台または片運転台などで多彩な車両があり、路線条件に応じて使われている。\n1両または、2両編成となっていて、これらを組み合わせて、3～6両で運転できる様になっている。\nキハ100、110系は電車並みの加速性能を持っているため、ローカル線のスピードアップに大きく寄与したほか、釜石線で走行している車両はリクライニングシート、飯山線の車両は展望式の座席配置となっているなど、様々なバリエーションがある。",
      "translation": ""
    }
  ]
}
