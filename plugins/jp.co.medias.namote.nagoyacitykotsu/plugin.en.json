  "texts": [
    {
      "key": "plugin.title",
      "source": "名古屋市交通局",
      "translation": ""
    },
    {
      "key": "contribution.{DD0220E0-7438-4E8B-A17D-C6116089B1CF}.name",
      "source": "名城線・4号線",
      "translation": ""
    },
    {
      "key": "contribution.{DD0220E0-7438-4E8B-A17D-C6116089B1CF}.company",
      "source": "名古屋市交通局",
      "translation": ""
    },
    {
      "key": "contribution.{DD0220E0-7438-4E8B-A17D-C6116089B1CF}.type",
      "source": "2000形",
      "translation": ""
    },
    {
      "key": "contribution.{DD0220E0-7438-4E8B-A17D-C6116089B1CF}.description",
      "source": "平成元年の世界デザイン博を機に、名城線・4号線に導入した車両で、以後既存車両の買い換え用として毎年導入している。\nこの車両は、従来からの車両設計の基本理念としているSpeedy Safety Silentの3Sを基礎にし、最新の技術を導入して、省エネルギー、省メンテナンスを実現するとともに乗客サービスの向上を図り、乗り心地の向上を始めとする居住性、快適性を追求した。",
      "translation": ""
    },
    {
      "key": "contribution.{00263A5E-ED2F-4DDB-BBB9-11BF0269C563}.name",
      "source": "東山線",
      "translation": ""
    },
    {
      "key": "contribution.{00263A5E-ED2F-4DDB-BBB9-11BF0269C563}.company",
      "source": "名古屋市交通局",
      "translation": ""
    },
    {
      "key": "contribution.{00263A5E-ED2F-4DDB-BBB9-11BF0269C563}.type",
      "source": "5050形",
      "translation": ""
    },
    {
      "key": "contribution.{00263A5E-ED2F-4DDB-BBB9-11BF0269C563}.description",
      "source": "昭和55年に5000形車両（チョッパ制御車）を導入して車両の冷房化をすすめてきましたが、さらに省エネルギー、省メンテナンスを実現すべく新形式5050形車両を導入した。\n従来からの車両設計の基本理念としているSpeedy Safety Silentの3Sを基礎にし、乗り心地の向上を始めとする居住性、快適性を追求し、「人にやさしい車両」とした。",
      "translation": ""
    }
  ]
}
