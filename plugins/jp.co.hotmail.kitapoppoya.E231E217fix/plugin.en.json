    },
    {
      "key": "contribution.{57644AE6-7FFA-A231-8FE0-7567-E231SOUBU}.company",
      "source": "JR東日本",
      "translation": ""
    },
    {
      "key": "contribution.{57644AE6-7FFA-A231-8FE0-7567-E231SOUBU}.type",
      "source": "E231系(fixed by kitapoppoya)",
      "translation": ""
    },
    {
      "key": "contribution.{57644AE6-7FFA-A231-8FE0-7567-E231SOUBU}.description",
      "source": "209系500番台導入後、残された高運転台103系と205系の置き換えのため登場。209系500番代とは車体は共通。",
      "translation": ""
    },
    {
      "key": "contribution.{57644AE6-7FFA-A231-8FE0-7567-E231JOBAN}.name",
