    {
      "key": "contribution.{{Freetrain-Type72-JNR-Mix}.description",
      "source": "一般タイプとジュラ電の混合編成です。",
      "translation": ""
    },
    {
      "key": "contribution.{Freetrain-Type72-JNR-sukasyoku}.name",
      "source": "73系スカ色",
      "translation": ""
