<!-- 
このファイルは業種を定義します。
記述例：
	<business id="000" name="業種名">
		<account fixed="0.25"/>
		<market scale="5000000000000" cycle="100" amplitude="5" ex_dependency="5" progressivity="1" />
		<weight brand="5" marketing="4" quality="3" />
	</business>

	id：companyタグのtype属性から参照される文字列
	name：業種名
	fixed:売上規模に対する固定経費率
	scale：市場規模(円貨)−同業種で売上げを分配します
	cycle：業種固有の景気周期(日)
	ampliture：業種固有の景気振幅(0-10)
	ex_dependency：景気影響度(0-10)−全体の景気指数による影響の受け安さ
	progressivity：業界の進歩性(0-10)−業界の栄枯盛衰の激しさ
	brand：ブランドの重要性(0-10)−競争においてブランド力が占める影響度
	marketing：販売力の重要性(0-10)−競争において販売力が占める影響度
	quality：品質の重要性(0-10)−競争において企業または製品の品質が占める影響度
-->
<companies>
	<!-- business tag descripts a 'business type' -->
	<business id="010" name="水産・林業">
		<!-- fixed:the ratio of fixed account against ideal sales amount-->
		<account fixed="0.30"/>
		<!-- scale:initial market scale of the business total-->
		<!-- cycle:proper business cycle (days) -->
		<!-- amplitude:proper business amplitude (0-10) -->
		<!-- ex_dependency:business dependency to the economy (0-10) -->
		<!-- progressivity:progressivity or competitive rate of the business (0-10) -->
		<market scale="5000000000000" cycle="365" amplitude="5" ex_dependency="5" progressivity="1" />
		<!-- brand:business waight of brand image (0-10) -->
		<!-- marketing:business waight of marketing ability (0-10) -->
