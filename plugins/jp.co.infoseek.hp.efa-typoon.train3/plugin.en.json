    {
      "key": "contribution.{57644AE6-7FFA-9KTK-8FE0-7567171D3CEF}.company",
      "source": "東京急行電鉄",
      "translation": "Tokyu Corporation"
    },
    {
      "key": "contribution.{57644AE6-7FFA-9KTK-8FE0-7567171D3CEF}.type",
      "source": "9000系",
      "translation": "9000 Series"
    },
    {
      "key": "contribution.{57644AE6-7FFA-9KTK-8FE0-7567171D3CEF}.description",
      "source": "東急東横線などで使われている9000系です。",
      "translation": "This is the 9000 Series used on the Tokyu Toyoko Line and other lines."
    },
    {
      "key": "contribution.{57644AE6-7FFA-2KTK-8FE0-7567171D3CEF}.company",
      "source": "東京急行電鉄",
      "translation": "Tokyu Corporation"
    },
    {
      "key": "contribution.{57644AE6-7FFA-2KTK-8FE0-7567171D3CEF}.type",
      "source": "2000系",
      "translation": "2000 Series"
    },
    {
      "key": "contribution.{57644AE6-7FFA-2KTK-8FE0-7567171D3CEF}.description",
      "source": "東急田園都市線で使われている2000系です。3編成しかないので結構レア？",
      "translation": "This is the 2000 Series used on the Tokyu Den-en-toshi Line. Only 3 sets exist, so it's quite rare?"
    },
    {
      "key": "contribution.{57644AE6-7FFA-1KTK-8FE0-7567171D3CEF}.company",
      "source": "東京急行電鉄",
      "translation": "Tokyu Corporation"
    },
    {
      "key": "contribution.{57644AE6-7FFA-1KTK-8FE0-7567171D3CEF}.type",
      "source": "1000系",
      "translation": "1000 Series"
    },
    {
      "key": "contribution.{57644AE6-7FFA-1KTK-8FE0-7567171D3CEF}.description",
      "source": "東急東横線、池上線などで使われている1000系です。東横線では地下鉄乗り入れ用に、池上線ではワンマン運転用に使われています。9000系との外見の大きな違いはドアとエアコンの室外機が3つなこと。",
      "translation": "This is the 1000 Series used on the Tokyu Toyoko Line, Ikegami Line, and others. On the Toyoko Line, it's used for subway through-service, and on the Ikegami Line, for one-man operation. The main external differences from the 9000 Series are the doors and having three outdoor air conditioner units."
    },
    {
      "key": "contribution.{57644AE6-7FFA-5KTK-8FE0-7567171D3CEF}.company",
      "source": "東京急行電鉄",
      "translation": "Tokyu Corporation"
    },
