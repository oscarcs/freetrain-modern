      "translation": ""
    },
    {
      "key": "contribution.{67705E9E-4ED1-T63-bd-FE45DAC33699}.description",
      "source": "一般車+ジュラ電の編成です",
      "translation": ""
    },
    {
      "key": "contribution.{3991CE43-T101-4923-JNR-9DA7803AW}.name",
      "source": "オレンジ",
      "translation": ""
    },
    {
      "key": "contribution.{3991CE43-T101-4923-JNR-9DA7803AW}.company",
