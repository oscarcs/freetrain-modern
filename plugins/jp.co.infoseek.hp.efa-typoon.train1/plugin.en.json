      "translation": "Kiha 201 Series"
    },
    {
      "key": "contribution.{57644AE6-7FFA-K201-8FE0-7567171D3CEF}.description",
      "source": "JR北海道のキハ201系です。",
      "translation": "This is JR Hokkaido's Kiha 201 Series."
    },
    {
      "key": "contribution.{57644AE6-7FFA-H201-8FE0-7567171D3CEF}.company",
      "source": "JR北海道",
      "translation": "JR Hokkaido"
    },
    {
      "key": "contribution.{57644AE6-7FFA-H201-8FE0-7567171D3CEF}.type",
      "source": "731系+キハ201系",
      "translation": "731 Series + Kiha 201 Series"
    },
    {
      "key": "contribution.{57644AE6-7FFA-H201-8FE0-7567171D3CEF}.description",
      "source": "6両のみ編成可能。",
      "translation": "Can only be formed with 6 cars."
    },
    {
      "key": "contribution.{57644AE6-7FFA-D115-8FE0-7567171D3CEF}.name",
      "source": "横須賀色",
      "translation": "Yokosuka Livery"
    },
    {
      "key": "contribution.{57644AE6-7FFA-D115-8FE0-7567171D3CEF}.company",
      "source": "JR東日本",
      "translation": "JR East"
    },
    {
      "key": "contribution.{57644AE6-7FFA-D115-8FE0-7567171D3CEF}.type",
      "source": "115系",
      "translation": "115 Series"
    },
    {
      "key": "contribution.{57644AE6-7FFA-D115-8FE0-7567171D3CEF}.description",
      "source": "中央本線などで見られる横須賀色の115系です。豊田電車区の115系が減ったため、スカ色115系も減っている。",
      "translation": "This is the 115 Series in Yokosuka livery, seen on the Chuo Main Line and other lines. As the number of 115 Series trains at Toyoda Depot has decreased, so has the number of Yokosuka-colored 115 Series trains."
    },
    {
      "key": "contribution.{57644AE6-7FFA-E115-8FE0-7567171D3CEF}.name",
      "source": "しなの鉄道色",
      "translation": "Shinano Railway livery"
    },
    {
      "key": "contribution.{57644AE6-7FFA-E115-8FE0-7567171D3CEF}.company",
      "source": "しなの鉄道",
      "translation": "Shinano Railway"
    },
    {
      "key": "contribution.{57644AE6-7FFA-E115-8FE0-7567171D3CEF}.type",
      "source": "115系",
      "translation": "115 Series"
    },
    {
      "key": "contribution.{57644AE6-7FFA-E115-8FE0-7567171D3CEF}.description",
      "source": "しなの鉄道にJR東日本から譲渡された115系です。",
      "translation": "This is the 115 series transferred from JR East to Shinano Railway."
    },
    {
      "key": "contribution.{57644AE6-7FFA-F115-8FE0-7567171D3CEF}.name",
      "source": "湘南色",
      "translation": "Shonan color"
    },
    {
      "key": "contribution.{57644AE6-7FFA-F115-8FE0-7567171D3CEF}.company",
      "source": "JR東日本",
      "translation": "JR East"
    },
    {
      "key": "contribution.{57644AE6-7FFA-F115-8FE0-7567171D3CEF}.type",
      "source": "115系",
      "translation": "115 Series"
    },
    {
      "key": "contribution.{57644AE6-7FFA-F115-8FE0-7567171D3CEF}.description",
      "source": "湘南色の115系です。",
      "translation": "This is a 115 Series in Shonan livery."
    },
    {
      "key": "contribution.{57644AE6-7FFA-I115-8FE0-7567171D3CEF}.name",
      "source": "湘南色",
      "translation": "Shonan color"
    },
    {
      "key": "contribution.{57644AE6-7FFA-I115-8FE0-7567171D3CEF}.company",
      "source": "JR東海",
      "translation": "JR Central"
    },
    {
      "key": "contribution.{57644AE6-7FFA-I115-8FE0-7567171D3CEF}.type",
      "source": "115系",
      "translation": "115 Series"
    },
    {
      "key": "contribution.{57644AE6-7FFA-I115-8FE0-7567171D3CEF}.description",
      "source": "湘南色の115系です。",
      "translation": "This is a 115 Series in Shonan livery."
    },
    {
      "key": "contribution.{57644AE6-7FFA-G115-8FE0-7567171D3CEF}.name",
      "source": "長野色",
      "translation": "Nagano livery"
    },
    {
      "key": "contribution.{57644AE6-7FFA-G115-8FE0-7567171D3CEF}.company",
      "source": "JR東日本",
      "translation": "JR East"
    },
    {
      "key": "contribution.{57644AE6-7FFA-G115-8FE0-7567171D3CEF}.type",
      "source": "115系",
      "translation": "115 Series"
    },
    {
      "key": "contribution.{57644AE6-7FFA-G115-8FE0-7567171D3CEF}.description",
      "source": "長野色の115系です。",
      "translation": "This is the 115 Series in Nagano livery."
    },
    {
      "key": "contribution.{57644AE6-7FFA-H115-8FE0-7567171D3CEF}.name",
      "source": "2000番台　身延色",
      "translation": "2000 series Minobu color"
    },
    {
      "key": "contribution.{57644AE6-7FFA-H115-8FE0-7567171D3CEF}.company",
      "source": "旧日本国有鉄道",
      "translation": "former JNR"
    },
    {
      "key": "contribution.{57644AE6-7FFA-H115-8FE0-7567171D3CEF}.type",
      "source": "115系",
      "translation": "115 Series"
    },
    {
      "key": "contribution.{57644AE6-7FFA-H115-8FE0-7567171D3CEF}.description",
      "source": "旧形国電を淘汰するため85年に新造された身延線向け115系2000番台。甲州のぶどうをイメージした塗装で身延線の名物だった。現在はこの塗装は見られない。",
      "translation": "The 115 Series 2000 sub-series for the Minobu Line, newly built in 1985 to replace old JNR electric trains. Its paint scheme, inspired by Koshu grapes, was a famous feature of the Minobu Line. This paint scheme is no longer seen today."
    },
    {
      "key": "contribution.{TYPHOON-JRE-115YAHI-HENSEI-7567171D3CEF}.name",
      "source": "弥彦線色",
      "translation": "Yahiko Line Livery"
    },
    {
      "key": "contribution.{TYPHOON-JRE-115YAHI-HENSEI-7567171D3CEF}.company",
      "source": "JR東日本",
      "translation": "JR East"
    },
    {
      "key": "contribution.{TYPHOON-JRE-115YAHI-HENSEI-7567171D3CEF}.type",
      "source": "115系",
      "translation": "115 Series"
    },
    {
      "key": "contribution.{TYPHOON-JRE-115YAHI-HENSEI-7567171D3CEF}.description",
      "source": "本当はこの色の中間車はないはず。12両まで編成可。",
      "translation": "Intermediate cars of this color should not exist. Can be formed into up to 12 cars."
    },
    {
      "key": "contribution.{57644AE6-7FFA-E215-8FE0-7567171D3CEF}.company",
      "source": "JR東日本",
      "translation": "JR East"
    },
    {
      "key": "contribution.{57644AE6-7FFA-E215-8FE0-7567171D3CEF}.type",
      "source": "215系",
      "translation": "215 Series"
    },
    {
      "key": "contribution.{57644AE6-7FFA-E215-8FE0-7567171D3CEF}.description",
      "source": "JR東日本215系。東海道線の混雑緩和をめざして開発された車両。「湘南ライナー」や「湘南新宿ライン」などに使用されている。",
      "translation": "JR East 215 Series. This rolling stock was developed to alleviate congestion on the Tokaido Line. It is used for services such as the \"Shonan Liner\" and \"Shonan-Shinjuku Line\"."
    },
    {
      "key": "contribution.{TYPHOON-JRW-113OBAMA-HENSEI-7567171D3CEF}.name",
      "source": "小浜線色",
      "translation": "Obama Line livery"
    },
    {
      "key": "contribution.{TYPHOON-JRW-113OBAMA-HENSEI-7567171D3CEF}.company",
      "source": "JR西日本",
      "translation": "JR West"
    },
    {
      "key": "contribution.{TYPHOON-JRW-113OBAMA-HENSEI-7567171D3CEF}.type",
      "source": "113系",
      "translation": "113 Series"
    },
    {
      "key": "contribution.{TYPHOON-JRW-113OBAMA-HENSEI-7567171D3CEF}.description",
      "source": "小浜線電化開業時に草津線・湖西線用の113系を改造・転用したもの。ラッシュ時に4両で運転。N40更新を受けているので転換クロスシートである。",
      "translation": "Modified and repurposed 113 Series trains from the Kusatsu Line and Kosei Line when the Obama Line was electrified. Operates with 4 cars during rush hour. Having undergone N40 refurbishment, it features convertible cross-seats."
    }
  ]
}
