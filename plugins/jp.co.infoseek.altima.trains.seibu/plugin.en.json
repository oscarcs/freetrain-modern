{
  "language": "en",
  "plugin": "jp.co.infoseek.altima.trains.seibu",
  "sourceManifest": "plugin.xml",
  "texts": [
    {
      "key": "plugin.title",
      "source": "西武鉄道車両パックVer2.0",
      "translation": ""
    },
    {
      "key": "contribution.{AltimaTRAINS-EC-SEIBU-101}.company",
      "source": "西武鉄道",
      "translation": ""
    },
    {
      "key": "contribution.{AltimaTRAINS-EC-SEIBU-101}.type",
      "source": "101系 ツートン塗装",
      "translation": ""
    },
    {
      "key": "contribution.{AltimaTRAINS-EC-SEIBU-101}.description",
      "source": "1969年に登場。同年に開業した秩父線の山岳路線に対応するため、大容量のモーターや抑速ブレーキを搭載している。廃車が進んでおり、多摩川線用のワンマン車など数本が残るのみ。",
      "translation": ""
    },
    {
      "key": "contribution.{AltimaTRAINS-EC-SEIBU-101-s}.company",
      "source": "西武鉄道",
      "translation": ""
    },
    {
      "key": "contribution.{AltimaTRAINS-EC-SEIBU-101-s}.type",
      "source": "101系 単色塗装",
      "translation": ""
    },
    {
      "key": "contribution.{AltimaTRAINS-EC-SEIBU-101-s}.description",
      "source": "1996年頃より、黄色とベージュのツートン塗装から黄色一色になった。",
      "translation": ""
    },
    {
      "key": "contribution.{AltimaTRAINS-EC-SEIBU-n101}.company",
      "source": "西武鉄道",
      "translation": ""
    },
    {
      "key": "contribution.{AltimaTRAINS-EC-SEIBU-n101}.type",
      "source": "新101系/301系 ツートン塗装",
      "translation": ""
    },
    {
      "key": "contribution.{AltimaTRAINS-EC-SEIBU-n101}.description",
      "source": "1979年に登場。メカニズム面では101系と大差無いが、高運転台やブラックフェイス化などでデザインが変更された。8連車は301系となっている。",
      "translation": ""
    },
    {
      "key": "contribution.{AltimaTRAINS-EC-SEIBU-n101-s}.company",
      "source": "西武鉄道",
      "translation": ""
    },
    {
      "key": "contribution.{AltimaTRAINS-EC-SEIBU-n101-s}.type",
      "source": "新101系/301系 単色塗装",
      "translation": ""
    },
    {
      "key": "contribution.{AltimaTRAINS-EC-SEIBU-n101-s}.description",
      "source": "1996年頃より、黄色とベージュのツートン塗装から黄色一色になった。",
      "translation": ""
    },
    {
      "key": "contribution.{AltimaTRAINS-EC-SEIBU-2000}.company",
      "source": "西武鉄道",
      "translation": ""
    },
    {
      "key": "contribution.{AltimaTRAINS-EC-SEIBU-2000}.type",
      "source": "2000系",
      "translation": ""
    },
    {
      "key": "contribution.{AltimaTRAINS-EC-SEIBU-2000}.description",
      "source": "新宿線用に1977年に登場。両開き4扉や界磁チョッパなど西武初の試みが多い車両。新旧合わせて400両以上の大所帯となっている。",
      "translation": ""
    },
    {
      "key": "contribution.{AltimaTRAINS-EC-SEIBU-2000-re}.company",
      "source": "西武鉄道",
      "translation": ""
    },
    {
      "key": "contribution.{AltimaTRAINS-EC-SEIBU-2000-re}.type",
      "source": "2000系更新車",
      "translation": ""
    },
    {
      "key": "contribution.{AltimaTRAINS-EC-SEIBU-2000-re}.description",
      "source": "1996年より更新工事を受けた車両が登場した。スカートの取り付けやシートの交換、近年の工事ではシングルアームパンタやLED表示器の採用などを実施。",
      "translation": ""
    },
    {
      "key": "contribution.{AltimaTRAINS-EC-SEIBU-n2000}.company",
      "source": "西武鉄道",
      "translation": ""
    },
    {
      "key": "contribution.{AltimaTRAINS-EC-SEIBU-n2000}.type",
      "source": "新2000系",
      "translation": ""
    },
    {
      "key": "contribution.{AltimaTRAINS-EC-SEIBU-n2000}.description",
      "source": "1988年に登場した2000系のマイナーチェンジ車。制御機器に変更は無く界磁チョッパを採用。前面のブラックフェイス化など外装、内装とも変化した。2連、4連、6連、8連が揃い、多摩川線を除く全線で運用される。",
      "translation": ""
    },
    {
      "key": "contribution.{AltimaTRAINS-EC-SEIBU-3000}.company",
      "source": "西武鉄道",
      "translation": ""
    },
    {
      "key": "contribution.{AltimaTRAINS-EC-SEIBU-3000}.type",
      "source": "3000系 ツートン塗装",
      "translation": ""
    },
    {
      "key": "contribution.{AltimaTRAINS-EC-SEIBU-3000}.description",
      "source": "池袋線向けに1983年に登場した車両。車体は新101系をベースとした3扉だが、界磁チョッパなど2000系と同一の機器類を採用している。全車8両固定編成。",
      "translation": ""
    },
    {
      "key": "contribution.{AltimaTRAINS-EC-SEIBU-3000-s}.company",
      "source": "西武鉄道",
      "translation": ""
    },
    {
      "key": "contribution.{AltimaTRAINS-EC-SEIBU-3000-s}.type",
      "source": "3000系 単色塗装",
      "translation": ""
    },
    {
      "key": "contribution.{AltimaTRAINS-EC-SEIBU-3000-s}.description",
      "source": "1996年頃より、黄色とベージュのツートン塗装から黄色一色になった。",
      "translation": ""
    },
    {
      "key": "contribution.{AltimaTRAINS-EC-SEIBU-6000}.company",
      "source": "西武鉄道",
      "translation": ""
    },
    {
      "key": "contribution.{AltimaTRAINS-EC-SEIBU-6000}.type",
      "source": "6000系",
      "translation": ""
    },
    {
      "key": "contribution.{AltimaTRAINS-EC-SEIBU-6000}.description",
      "source": "地下鉄乗入対応車として1992年に登場。西武初のステンレス製車体にGTO-VVVF、黄帯の有楽町線との誤乗防止のためブルーの帯を纏い、従来の西武電車とは大きくイメージが異なる車両となった。10両編成のみで、当初池袋線に投入されたが、直通運用のできない初期車は転属し、新宿線・拝島線で運用されている。",
      "translation": ""
    },
    {
      "key": "contribution.{AltimaTRAINS-EC-SEIBU-6050}.company",
      "source": "西武鉄道",
      "translation": ""
    },
    {
      "key": "contribution.{AltimaTRAINS-EC-SEIBU-6050}.type",
      "source": "6050系",
      "translation": ""
    },
    {
      "key": "contribution.{AltimaTRAINS-EC-SEIBU-6050}.description",
      "source": "1996年からはアルミ車体を採用し軽量化した6050系が登場。2年後の最終増備車は戸袋窓の廃止などさらに軽量化を進めた。",
      "translation": ""
    },
    {
      "key": "contribution.{AltimaTRAINS-EC-SEIBU-10000}.company",
      "source": "西武鉄道",
      "translation": ""
    },
    {
      "key": "contribution.{AltimaTRAINS-EC-SEIBU-10000}.type",
      "source": "10000系",
      "translation": ""
    },
    {
      "key": "contribution.{AltimaTRAINS-EC-SEIBU-10000}.description",
      "source": "5000系レッドアローの後継として1993年に登場。一部編成以外の足回りは101系の流用品。",
      "translation": ""
    },
    {
      "key": "contribution.{AltimaTRAINS-EC-SEIBU-20000}.company",
      "source": "西武鉄道",
      "translation": ""
    },
    {
      "key": "contribution.{AltimaTRAINS-EC-SEIBU-20000}.type",
      "source": "20000系",
      "translation": ""
    },
    {
      "key": "contribution.{AltimaTRAINS-EC-SEIBU-20000}.description",
      "source": "新宿線向けの地上線専用車として2000年に登場。IGBT-VVVFや無塗装アルミ車体などを採用し省エネ、騒音やサイクルコストの低減などを実現している。10連と8連があり、現在は池袋線でも運用されている。",
      "translation": ""
    }
  ]
}
