{
  "language": "en",
  "plugin": "org.kohsuke.freetrain.trains.teha",
  "sourceManifest": "plugin.xml",
  "texts": [
    {
      "key": "plugin.title",
      "source": "ては",
      "translation": "Teha"
    },
    {
      "key": "contribution.{4161129C-2C3C-493A-B703-16825455D353}.name",
      "source": "トワイライトエクスプレス",
      "translation": "Twilight Express"
    },
    {
      "key": "contribution.{4161129C-2C3C-493A-B703-16825455D353}.company",
      "source": "JR西日本",
      "translation": "JR West"
    },
    {
      "key": "contribution.{4161129C-2C3C-493A-B703-16825455D353}.description",
      "source": "大阪～札幌間を走行する豪華寝台特急。ホテル並みの設備を揃える。",
      "translation": "A luxurious sleeper limited express running between Osaka and Sapporo. It offers hotel-level amenities."
    },
    {
      "key": "contribution.{4B41FC2E-DFFE-4F57-9412-74F2A368577C}.name",
      "source": "USJ　アメリカの町並",
      "translation": "USJ American Townscape"
    },
    {
      "key": "contribution.{4B41FC2E-DFFE-4F57-9412-74F2A368577C}.company",
      "source": "JR西日本",
      "translation": "JR West"
    },
    {
      "key": "contribution.{4B41FC2E-DFFE-4F57-9412-74F2A368577C}.type",
      "source": "103系",
      "translation": "103 Series"
    },
    {
      "key": "contribution.{4B41FC2E-DFFE-4F57-9412-74F2A368577C}.description",
      "source": "USJの開業に合わせてラッピングされた103系、全車N40改造車である。(メモリ食い…)",
      "translation": "103 Series wrapped for the opening of USJ, all cars are N40 modified. (Memory intensive...)"
    },
    {
      "key": "contribution.{5174FFB3-C406-41C1-9198-CD23D40DCA3F}.name",
      "source": "USJ　ユニバーサルグローブ",
      "translation": "USJ Universal Globe"
    },
    {
      "key": "contribution.{5174FFB3-C406-41C1-9198-CD23D40DCA3F}.company",
      "source": "JR西日本",
      "translation": "JR West"
    },
    {
      "key": "contribution.{5174FFB3-C406-41C1-9198-CD23D40DCA3F}.type",
      "source": "103系",
      "translation": "103 Series"
    },
    {
      "key": "contribution.{5174FFB3-C406-41C1-9198-CD23D40DCA3F}.description",
      "source": "USJの開業に合わせてラッピングされた103系、全車N40改造車である。",
      "translation": "103 Series wrapped for the opening of USJ, all cars are N40 modified."
    },
    {
      "key": "contribution.{2C7C4B10-8BBB-4196-873A-764A5BFC53D0}.name",
      "source": "103系朱色　低運転台",
      "translation": "103 Series Vermilion Low Cab"
    },
    {
      "key": "contribution.{2C7C4B10-8BBB-4196-873A-764A5BFC53D0}.company",
      "source": "JR西日本",
      "translation": "JR West"
    },
    {
      "key": "contribution.{2C7C4B10-8BBB-4196-873A-764A5BFC53D0}.type",
      "source": "103系",
      "translation": "103 Series"
    },
    {
      "key": "contribution.{2C7C4B10-8BBB-4196-873A-764A5BFC53D0}.description",
      "source": "N40延命改造を受けた103系、シート等は207系レベルに変更されているが乗り心地は103系…　大阪環状線等で使用されている",
      "translation": "103 Series that underwent N40 life extension modification. Seats and other features were changed to 207 Series level, but the ride comfort is still 103 Series... Used on the Osaka Loop Line and others."
    },
    {
      "key": "contribution.{97C123C3-89A2-488C-AB83-1D9AB108741F}.name",
      "source": "207系　0番台",
      "translation": "207 Series 0 series"
    },
    {
      "key": "contribution.{97C123C3-89A2-488C-AB83-1D9AB108741F}.company",
      "source": "JR西日本",
      "translation": "JR West"
    },
    {
      "key": "contribution.{97C123C3-89A2-488C-AB83-1D9AB108741F}.type",
      "source": "207系",
      "translation": "207 Series"
    },
    {
      "key": "contribution.{97C123C3-89A2-488C-AB83-1D9AB108741F}.description",
      "source": "JR西日本の標準型通勤車、乗り心地が良いがかなり高額なのが…ちなみにJR東日本に900番台が在籍しているが、全く別物である。",
      "translation": "JR West's standard commuter train. It offers a comfortable ride but is quite expensive... Incidentally, the 900 sub-series exists at JR East, but it is a completely different model."
    },
    {
      "key": "contribution.{B2F41693-134A-4044-9D13-49990166AD47}.name",
      "source": "207系　学研都市、東西線",
      "translation": "207 Series Gakkentoshi, Tozai Line"
    },
    {
      "key": "contribution.{B2F41693-134A-4044-9D13-49990166AD47}.company",
      "source": "JR西日本",
      "translation": "JR West"
    },
    {
      "key": "contribution.{B2F41693-134A-4044-9D13-49990166AD47}.type",
      "source": "207系",
      "translation": "207 Series"
    },
    {
      "key": "contribution.{B2F41693-134A-4044-9D13-49990166AD47}.description",
      "source": "学研都市、東西線では4+3で走っている、松井山手で前3両を切り離して運転するからである。また、東西線区間はダブルパンタで走行する。",
      "translation": "It operates as 4+3 on the Gakken Toshi and Tozai Lines, as the front 3 cars are detached at Matsuiyamate. Also, it runs with double pantographs on the Tozai Line section."
    }
  ]
}
