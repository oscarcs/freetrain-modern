    {
      "key": "contribution.{57644AE6-7FFA-H731-8FE0-7567171D3CEF}.description",
      "source": "JR北海道の731系です。",
      "translation": "This is JR Hokkaido's 731 Series."
    },
    {
      "key": "contribution.{57644AE6-7FFA-K201-8FE0-7567171D3CEF}.company",
