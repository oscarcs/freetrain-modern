  "texts": [
    {
      "key": "plugin.title",
      "source": "ジョイフルトレインセット",
      "translation": "Joyful Train Set"
    },
    {
      "key": "contribution.{2E08F220-3DDB-11D8-968B-0800460222F0-titech-silpheed}.name",
      "source": "シルフィード",
      "translation": "Sylphide"
    },
    {
      "key": "contribution.{2E08F220-3DDB-11D8-968B-0800460222F0-titech-silpheed}.company",
      "source": "JR東日本",
      "translation": "JR East"
    },
    {
      "key": "contribution.{2E08F220-3DDB-11D8-968B-0800460222F0-titech-silpheed}.type",
      "source": "485系",
      "translation": "485 Series"
    },
    {
      "key": "contribution.{2E08F220-3DDB-11D8-968B-0800460222F0-titech-silpheed}.description",
      "source": "「シルフィード」は485系交直流型特急電車をベースに、大幅な改造を加えて誕生した3両編成のジョイフルトレインです。\n機関車牽引による非電化区間への乗り入れを考慮し、先頭車に電源用ディーゼルエンジンを搭載しています。",
      "translation": "The 'Sylphide' is a 3-car joyfultrain born from extensive modifications to the 485 Series AC/DC limited express electric train. Considering its operation on non-electrified sections with locomotive traction, the lead cars are equipped with diesel engines for power generation."
    },
    {
      "key": "contribution.{B038C0A1-3D35-11D8-968B-0800460222F0-titech-fureaipal}.name",
      "source": "ふれあいパル",
      "translation": "Fureai Pal"
    },
    {
      "key": "contribution.{B038C0A1-3D35-11D8-968B-0800460222F0-titech-fureaipal}.company",
      "source": "旧日本国有鉄道",
      "translation": "former JNR"
    },
    {
      "key": "contribution.{B038C0A1-3D35-11D8-968B-0800460222F0-titech-fureaipal}.type",
      "source": "キハ58系",
      "translation": "Kiha 58 Series"
    },
    {
      "key": "contribution.{B038C0A1-3D35-11D8-968B-0800460222F0-titech-fureaipal}.description",
      "source": "ふれあいパルは昭和61年3月に登場した山口鉄道部に所属する気動車2両のジョイフルトレイン。\n貫通扉撤去したうえ、助手席側を展望スペースにしているのが特徴。",
      "translation": "Fureai Pal is a 2-car diesel railcar joyful train belonging to the Yamaguchi Railway Division, introduced in March Showa 61 (1986). Its features include the removal of the gangway door and the conversion of the co-driver's side into an observation space."
    },
    {
      "key": "contribution.{B038C0A2-3D35-11D8-968B-0800460222F0-titech-niitsu-carpetl}.name",
