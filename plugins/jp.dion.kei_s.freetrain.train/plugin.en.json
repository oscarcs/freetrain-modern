    {
      "key": "contribution.{FreeTrain-N1K2J-KeiH-TrainHensei-KIHA82}.type",
      "source": "キハ 82",
      "translation": ""
    },
    {
      "key": "contribution.{FreeTrain-N1K2J-KeiH-TrainHensei-KIHA82}.description",
      "source": "全国の非電化区間での特急サービスアップのため導入された初の気動車特急。初期のキハ81型はボンネット車体であった。晩年は主に北海道・紀勢方面で活躍。",
      "translation": ""
    },
    {
      "key": "contribution.{FreeTrain-N1K2J-KeiH-TrainHensei-DC0001}.name",
      "source": "気動車混合編成",
      "translation": ""
    },
    {
      "key": "contribution.{FreeTrain-N1K2J-KeiH-TrainHensei-DC0001}.company",
      "source": "旧日本国有鉄道",
      "translation": ""
    },
    {
      "key": "contribution.{FreeTrain-N1K2J-KeiH-TrainHensei-DC0001}.type",
      "source": "一般型気動車",
      "translation": ""
    },
    {
      "key": "contribution.{FreeTrain-N1K2J-KeiH-TrainHensei-DC0001}.description",
      "source": "一般型であるキハ20、30、45、40型および急行型であるキハ58型気動車などを混合した編成。雑多な車種と塗装が特徴。郵便車や荷物車を組み込むこともある。",
      "translation": ""
    },
    {
      "key": "contribution.{FreeTrain-N1K2J-KeiH-TrainHensei-DC0002}.name",
      "source": "キハ４５",
      "translation": ""
    },
    {
      "key": "contribution.{FreeTrain-N1K2J-KeiH-TrainHensei-DC0002}.company",
