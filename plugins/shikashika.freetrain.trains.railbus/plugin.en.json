      "translation": ""
    },
    {
      "key": "contribution.{FreeTrain-Shika-RailroadTrain-miki-miki180-railbus}.type",
      "source": "ミキ180",
      "translation": ""
    },
    {
      "key": "contribution.{FreeTrain-Shika-RailroadTrain-miki-miki180-railbus}.description",
      "source": "富士重工製造のLE-Car(ライトエコノミー・ディーゼルカー)のレールバスです。",
      "translation": ""
    },
    {
      "key": "contribution.{FreeTrain-Shika-RailroadTrain-miki-hurawa1985-1-railbus}.name",
      "source": "レールバス",
      "translation": ""
