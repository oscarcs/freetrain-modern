    {
      "key": "plugin.title",
      "source": "車両セット　1号車",
      "translation": "Train set Car 1"
    },
    {
      "key": "contribution.{57644AE6-7FFA-E351-8FE0-7567171D3CEF}.name",
      "source": "スーパーあずさ",
      "translation": "Super Azusa"
    },
    {
