    {
      "key": "contribution.{AD070310-7653-11D7-A4B7-ECJ475-K}.name",
      "source": "北陸急行電車",
      "translation": ""
    },
    {
      "key": "contribution.{AD070310-7653-11D7-A4B7-ECJ475-K}.company",
