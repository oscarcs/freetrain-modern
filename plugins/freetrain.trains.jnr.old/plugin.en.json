  "texts": [
    {
      "key": "plugin.title",
      "source": "旧型国電プラグイン",
      "translation": ""
    },
    {
      "key": "contribution.{Freetrain-T63-JNR-duralumin}.name",
      "source": "63系900番台ジュラ電",
      "translation": ""
    },
    {
      "key": "contribution.{Freetrain-T63-JNR-duralumin}.company",
      "source": "旧日本国有鉄道",
      "translation": ""
    },
    {
      "key": "contribution.{Freetrain-T63-JNR-duralumin}.type",
      "source": "旧型国電",
      "translation": ""
    },
    {
      "key": "contribution.{Freetrain-T63-JNR-duralumin}.description",
      "source": "鋼体車体の試作車としてジュラルミンで車体を作られ\n\t\t\t車内は蛍光灯採用され通称ジュラ電といわれましたが\n\t\t\t無塗装ため腐食が激しく一般車両のように塗装され、\n\t\t\t最終的には一般の鋼体車体に改造されました。",
      "translation": ""
    },
    {
      "key": "contribution.{Freetrain-Oldtype-JNR-2doors-budou}.name",
      "source": "モハ62・クハ77",
      "translation": ""
    },
    {
      "key": "contribution.{Freetrain-Oldtype-JNR-2doors-budou}.company",
      "source": "旧日本国有鉄道",
      "translation": ""
    },
    {
      "key": "contribution.{Freetrain-Oldtype-JNR-2doors-budou}.type",
      "source": "旧型国電",
      "translation": ""
    },
    {
      "key": "contribution.{Freetrain-Oldtype-JNR-2doors-budou}.description",
      "source": "戦前型の旧型電車。ローカル線用にクロスシート化改造されたタイプです",
      "translation": ""
    },
    {
      "key": "contribution.{Freetrain-Oldtype-JNR-ooito}.name",
      "source": "大糸線",
      "translation": ""
    },
    {
      "key": "contribution.{Freetrain-Oldtype-JNR-ooito}.company",
      "source": "旧日本国有鉄道",
      "translation": ""
    },
    {
      "key": "contribution.{Freetrain-Oldtype-JNR-ooito}.type",
      "source": "旧型国電",
      "translation": ""
    },
    {
      "key": "contribution.{Freetrain-Oldtype-JNR-ooito}.description",
      "source": "大糸線で活躍していたクモハ43・クモハ60・クハ55です。\n\t\t\t当時としては珍しくスカイブルー一色に塗られており\n\t\t\tクモユニ81003と共に1981年まで活躍しました。",
      "translation": ""
    },
    {
      "key": "contribution.{{Freetrain-Type72-JNR-budou}.name",
      "source": "73系電車近代化改造車",
      "translation": ""
    },
    {
      "key": "contribution.{{Freetrain-Type72-JNR-budou}.company",
      "source": "旧日本国有鉄道",
      "translation": ""
    },
    {
      "key": "contribution.{{Freetrain-Type72-JNR-budou}.type",
      "source": "旧型国電",
      "translation": ""
    },
    {
      "key": "contribution.{{Freetrain-Type72-JNR-budou}.description",
      "source": "桜木町事故を教訓とし、63系電車を諸改造した形式。\n\t\t\t63系電車は20メートルの車体に4扉と後の通勤型電車の原型となった車両です。\n\t\t\t戦後に足回りの改良のほか車体の鋼体化・101系に準じた前面になった近代化改造されたタイプです。",
      "translation": ""
    },
    {
      "key": "contribution.{{Freetrain-Type72-JNR-oldtype}.name",
      "source": "73系ぶどう色",
      "translation": ""
    },
    {
      "key": "contribution.{{Freetrain-Type72-JNR-oldtype}.company",
      "source": "旧日本国有鉄道",
      "translation": ""
    },
    {
      "key": "contribution.{{Freetrain-Type72-JNR-oldtype}.type",
      "source": "旧型国電",
      "translation": ""
    },
    {
      "key": "contribution.{{Freetrain-Type72-JNR-oldtype}.description",
      "source": "足回り等の近代化改造前の旧タイプです。。",
      "translation": ""
    },
    {
      "key": "contribution.{{Freetrain-Type72-JNR-Mix}.name",
      "source": "73系ぶどう色+ジュラ電",
      "translation": ""
    },
    {
      "key": "contribution.{{Freetrain-Type72-JNR-Mix}.company",
      "source": "旧日本国有鉄道",
      "translation": ""
