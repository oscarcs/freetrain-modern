<?xml version="1.0" encoding="Shift_JIS" ?>
<plug-in>
	<title>壦慄拰僞僀僾儗儞僈嫶媟</title>
	<author>傝偍傝偍夵憿仼埢悾僸儘</author>
	<homepage>http://www.hiyohiyo.info/~riorio/freetrain/</homepage>
	
	<depends on="org.kohsuke.freetrain.rail.electricPole" />

	<contribution type="picture" id="{riorio-FreeTrain-AYASE-Hiro-RailStructureImg-Base-Right}">
		<picture src="tras_s.bmp" />
	</contribution>
	<contribution type="picture" id="{riorio-FreeTrain-AYASE-Hiro-RailStructureImg-Base-Left}">
		<picture src="tras_e.bmp" />
	</contribution>
	
	
	<contribution type="electricPole" id="{riorio-FreeTrain-RailStructureImpl-Base-Left}">
		<name>揝嫶(嫶媟, 嵍)</name>
		<sprite>
			<picture ref="{riorio-FreeTrain-AYASE-Hiro-RailStructureImg-Base-Left}"/>
		</sprite>
	</contribution>
	<contribution type="electricPole" id="{riorio-FreeTrain-AYASE-Hiro-RailStructureImpl-Base-Right-Red}">
		<name>揝嫶(嫶媟, 塃)</name>
		<sprite>
			<picture ref="{riorio-FreeTrain-AYASE-Hiro-RailStructureImg-Base-Right}"/>
		</sprite>
	</contribution>

</plug-in>
