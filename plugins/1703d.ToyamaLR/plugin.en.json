      "key": "plugin.title",
      "source": "新潟車両セット",
      "translation": "Niigata train set"
    },
    {
      "key": "contribution.{CyberExpress1703d-toyama0600r}.name",
      "source": "01　レッド",
      "translation": "01 Red"
    },
    {
      "key": "contribution.{CyberExpress1703d-toyama0600r}.company",
      "source": "富山ライトレール",
      "translation": "Toyama Light Rail"
    },
    {
      "key": "contribution.{CyberExpress1703d-toyama0600r}.type",
      "source": "0600形",
      "translation": "0600 series"
    },
    {
      "key": "contribution.{CyberExpress1703d-toyama0600r}.description",
      "source": "2両編成のみ。JR富山港線をLRTとして蘇らせた路線を走る、低床の路面電車です。",
      "translation": "2-car formation only. A low-floor tram that runs on the JR Toyama Port Line, which was revived as an LRT."
    },
