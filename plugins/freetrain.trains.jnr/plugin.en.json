      "translation": ""
    },
    {
      "key": "contribution.{8B8C5CB2-T80-43a5-kansaiEX-4528788BF74E}.type",
      "source": "80系電車",
      "translation": ""
    },
    {
      "key": "contribution.{8B8C5CB2-T80-43a5-kansaiEX-4528788BF74E}.description",
      "source": "関西地方で急マークのヘッドマークをつけて快速として走行してました。",
      "translation": ""
    },
    {
      "key": "contribution.{67705E9E-4ED1-T63-duralumin-FE45DAC33699}.name",
      "source": "900番台ジュラ電",
      "translation": ""
    },
    {
      "key": "contribution.{67705E9E-4ED1-T63-duralumin-FE45DAC33699}.company",
      "source": "旧日本国有鉄道",
      "translation": ""
    },
    {
      "key": "contribution.{67705E9E-4ED1-T63-duralumin-FE45DAC33699}.type",
      "source": "62/63系",
      "translation": ""
    },
    {
      "key": "contribution.{67705E9E-4ED1-T63-duralumin-FE45DAC33699}.description",
      "source": "63形900番台はジュラルミンで車体を作られ、\n\t\t\t通称ジュラ電といわれましたが無塗装ため腐食が激しく\n\t\t\t一般車両のように塗装され、最終的には鋼体車体に改造されました。",
      "translation": ""
    },
    {
      "key": "contribution.{67705E9E-4ED1-T63-budou-FE45DAC33699}.name",
      "source": "ぶどう色",
      "translation": ""
    },
    {
      "key": "contribution.{67705E9E-4ED1-T63-budou-FE45DAC33699}.company",
      "source": "旧日本国有鉄道",
      "translation": ""
    },
    {
      "key": "contribution.{67705E9E-4ED1-T63-budou-FE45DAC33699}.type",
      "source": "62/63系",
      "translation": ""
    },
    {
      "key": "contribution.{67705E9E-4ED1-T63-budou-FE45DAC33699}.description",
      "source": "初期は戦時中に作られた電車で、戦後になると電車不足から大量に増備去れました。\n\t\t\t鋼体車、半鋼体車のほか、ジュラルミンでつくられたジュラ電などがありました。",
      "translation": ""
    },
    {
      "key": "contribution.{67705E9E-4ED1-T63A-budou-FE45DAC33699}.name",
      "source": "ぶどう色(2扉・クロスシート)",
      "translation": ""
    },
    {
      "key": "contribution.{67705E9E-4ED1-T63A-budou-FE45DAC33699}.company",
      "source": "旧日本国有鉄道",
      "translation": ""
    },
    {
      "key": "contribution.{67705E9E-4ED1-T63A-budou-FE45DAC33699}.type",
      "source": "62/63系",
      "translation": ""
    },
    {
      "key": "contribution.{67705E9E-4ED1-T63A-budou-FE45DAC33699}.description",
      "source": "ローカル専用にクロスシート化および、2扉化されたタイプ。",
      "translation": ""
    },
    {
      "key": "contribution.{67705E9E-4ED1-T63-bd-FE45DAC33699}.name",
      "source": "ぶどう色+ジュラ電",
      "translation": ""
    },
    {
      "key": "contribution.{67705E9E-4ED1-T63-bd-FE45DAC33699}.company",
      "source": "旧日本国有鉄道",
      "translation": ""
    },
    {
      "key": "contribution.{67705E9E-4ED1-T63-bd-FE45DAC33699}.type",
