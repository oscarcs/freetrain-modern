    {
      "key": "plugin.title",
      "source": "京急旧1000形（黒幕車）",
      "translation": "Keikyu former 1000 Series (black curtain car)"
    },
    {
      "key": "contribution.{8482AE3A-8EC8-44B8-9D8A-7F9846E19F0C}.name",
