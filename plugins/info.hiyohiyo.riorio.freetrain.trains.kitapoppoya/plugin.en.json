{
  "language": "en",
  "plugin": "info.hiyohiyo.riorio.freetrain.trains.kitapoppoya",
  "sourceManifest": "plugin.xml",
  "texts": [
    {
      "key": "plugin.title",
      "source": "203系・207系900・209系1000・E231系東海道・営団01,02",
      "translation": ""
    },
    {
      "key": "contribution.{riorio-kitapoppoya-203jobanchiyoda-8080-BCF7E8DC11FF}.name",
      "source": "常磐緩行線・千代田線直通",
      "translation": ""
    },
    {
      "key": "contribution.{riorio-kitapoppoya-203jobanchiyoda-8080-BCF7E8DC11FF}.company",
      "source": "JR東日本",
      "translation": ""
    },
    {
      "key": "contribution.{riorio-kitapoppoya-203jobanchiyoda-8080-BCF7E8DC11FF}.type",
      "source": "203系",
      "translation": ""
    },
    {
      "key": "contribution.{riorio-kitapoppoya-203jobanchiyoda-8080-BCF7E8DC11FF}.description",
      "source": "常磐緩行線から千代田線に直通乗り入れする車両として、それまで使用されていた103系1000番台を置き換えるため1982年から国鉄が製造した通勤型電車。軽量アルミ車体に回生ブレーキ付チョッパ制御を採用し、省エネ・低発熱を実現すると共に冷房も搭載された。\nJR化後もこの線の主力として使用されてきたが、E233系2000番台の増備によって廃車が始まっている。",
      "translation": ""
    },
    {
      "key": "contribution.{riorio-kitapoppoya-207-900jobanchiyoda-D8638258151F}.name",
      "source": "常磐緩行線・千代田線直通",
      "translation": ""
    },
    {
      "key": "contribution.{riorio-kitapoppoya-207-900jobanchiyoda-D8638258151F}.company",
      "source": "JR東日本",
      "translation": ""
    },
    {
      "key": "contribution.{riorio-kitapoppoya-207-900jobanchiyoda-D8638258151F}.type",
      "source": "207系900番台",
      "translation": ""
    },
    {
      "key": "contribution.{riorio-kitapoppoya-207-900jobanchiyoda-D8638258151F}.description",
      "source": "常磐緩行線から千代田線に直通乗り入れする車両として、1986年に1編成だけ国鉄が製造した通勤型電車。205系に準じた軽量ステンレス車体とし、国鉄で初めてVVVF制御が採用された。当時はVVVF制御器が非常に高価だったこと、常磐緩行線や他の線区でこの形式の新製が必要とされていなかったことから、その後の増備が行われなかった。\n同じ207系を名乗ってはいるが、JR西日本が使用している207系0番台・1000番台とはまったくの別形式である。\nJR化後も引き続き使用されてきたが、E233系2000番台の増備によって廃車されることが決まっている。",
      "translation": ""
    },
    {
      "key": "contribution.{riorio-kitapoppoya-209-1000jobanchiyoda-4981CB7BB03B}.name",
      "source": "1000番台 常磐緩行線・千代田線直通",
      "translation": ""
    },
    {
      "key": "contribution.{riorio-kitapoppoya-209-1000jobanchiyoda-4981CB7BB03B}.company",
      "source": "JR東日本",
      "translation": ""
    },
    {
      "key": "contribution.{riorio-kitapoppoya-209-1000jobanchiyoda-4981CB7BB03B}.type",
      "source": "209系",
      "translation": ""
    },
    {
      "key": "contribution.{riorio-kitapoppoya-209-1000jobanchiyoda-4981CB7BB03B}.description",
      "source": "常磐緩行線から千代田線に直通乗り入れする車両の必要本数が増加したため、1999年にJR東日本が2編成製造した通勤型電車。中央総武緩行線から東西線に直通する500番台に準じた設計となっている。\nその後の増備は行われず、2008年から開始の老朽化した203系等を置き換えるのは、E233系の増備でまかなわれることとなった。",
      "translation": ""
    },
    {
      "key": "contribution.{riorio-kitapoppoya-tokyometro01-ginzaline-0D7CF234710C}.name",
      "source": "銀座線",
      "translation": ""
    },
    {
      "key": "contribution.{riorio-kitapoppoya-tokyometro01-ginzaline-0D7CF234710C}.company",
      "source": "帝都高速度交通営団",
      "translation": ""
    },
    {
      "key": "contribution.{riorio-kitapoppoya-tokyometro01-ginzaline-0D7CF234710C}.type",
      "source": "01系",
      "translation": ""
    },
    {
      "key": "contribution.{riorio-kitapoppoya-tokyometro01-ginzaline-0D7CF234710C}.description",
      "source": "老朽化した銀座線の車両を置き換えるため、帝都高速度交通営団が1984年から製造した地下鉄用通勤型電車。アルミ車体で、制御器は製造年度によりチョッパ制御とVVVF制御とがある。パンタグラフではなく、第三軌条から集電する方式である。",
      "translation": ""
    },
    {
      "key": "contribution.{riorio-kitapoppoya-tokyometro02-marunouchiline-9092A2B5D6FC}.name",
      "source": "丸ノ内線",
      "translation": ""
    },
    {
      "key": "contribution.{riorio-kitapoppoya-tokyometro02-marunouchiline-9092A2B5D6FC}.company",
      "source": "帝都高速度交通営団",
      "translation": ""
    },
    {
      "key": "contribution.{riorio-kitapoppoya-tokyometro02-marunouchiline-9092A2B5D6FC}.type",
      "source": "02系",
      "translation": ""
    },
    {
      "key": "contribution.{riorio-kitapoppoya-tokyometro02-marunouchiline-9092A2B5D6FC}.description",
      "source": "老朽化した丸ノ内線の車両を置き換えるため、帝都高速度交通営団が1988年から製造した地下鉄用通勤型電車。アルミ車体で、制御器は製造年度によりチョッパ制御とVVVF制御とがある。パンタグラフではなく、第三軌条から集電する方式である。",
      "translation": ""
    },
    {
      "key": "contribution.{riorio-kitapoppoya-jre231-tokaidoddts-349DE7270A56}.name",
      "source": "2階建グリーン車入り・東海道線等",
      "translation": ""
    },
    {
      "key": "contribution.{riorio-kitapoppoya-jre231-tokaidoddts-349DE7270A56}.company",
      "source": "JR東日本",
      "translation": ""
    },
    {
      "key": "contribution.{riorio-kitapoppoya-jre231-tokaidoddts-349DE7270A56}.type",
      "source": "E231系",
      "translation": ""
    },
    {
      "key": "contribution.{riorio-kitapoppoya-jre231-tokaidoddts-349DE7270A56}.description",
      "source": "2000年から宇都宮線向けに製造が開始されたE231系1000番台近郊タイプだったが、湘南新宿ラインへのグリーン車連結及び同番台新造により東海道線113系の置き換えを行うため、2004年から2階建てグリーン車が増備され、10両基本編成中に2両が連結されることとなった。また2006年からは、上野発着の宇都宮線・高崎線でもグリーン車が連結されることとなった。",
      "translation": ""
    },
    {
      "key": "contribution.{riorio-kitapoppoya-jre531-jobanddts-105FA5926D74}.name",
      "source": "2階建グリーン車入り",
      "translation": ""
    },
    {
      "key": "contribution.{riorio-kitapoppoya-jre531-jobanddts-105FA5926D74}.company",
      "source": "JR東日本",
      "translation": ""
    },
    {
      "key": "contribution.{riorio-kitapoppoya-jre531-jobanddts-105FA5926D74}.type",
      "source": "E531系",
      "translation": ""
    },
    {
      "key": "contribution.{riorio-kitapoppoya-jre531-jobanddts-105FA5926D74}.description",
      "source": "老朽化した415系を置き換えスピードアップするため、2005年から常磐線向けに製造が開始された交直流近郊型電車がE531系。最高速度130km/h。2007年からは10両基本編成に2両の2階建てグリーン車が連結されることとなった。",
      "translation": ""
    }
  ]
}
