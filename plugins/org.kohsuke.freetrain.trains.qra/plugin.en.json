    },
    {
      "key": "contribution.{ADF87135-8F9C-1C24-9B45-04F846A0479D}.company",
      "source": "JR東日本",
      "translation": "JR East"
    },
    {
      "key": "contribution.{ADF87135-8F9C-1C24-9B45-04F846A0479D}.type",
      "source": "EF81+24系",
      "translation": "EF81 + 24 Series"
    },
    {
      "key": "contribution.{ADF87135-8F9C-1C24-9B45-04F846A0479D}.description",
      "source": "1988年3月、青函トンネルの開通により、上野～札幌間に設定された寝台特急。個室寝台が設けられたほか、食堂車やロビーカーも連結されている。上野～青森間は、交流・直流兼用のEF81が牽引する。",
      "translation": "A sleeper limited express established between Ueno and Sapporo with the opening of the Seikan Tunnel in March 1988. In addition to private compartments, dining cars and lounge cars are also connected. Between Ueno and Aomori, it is hauled by the EF81, which supports both AC and DC."
    },
    {
      "key": "contribution.{DC183AAA-1069-11D7-AA41-000740323A8D}.name",
      "source": "オホーツク9,10号",
      "translation": "Okhotsk 9, 10"
    },
    {
      "key": "contribution.{DC183AAA-1069-11D7-AA41-000740323A8D}.company",
      "source": "JR北海道",
      "translation": "JR Hokkaido"
    },
    {
      "key": "contribution.{DC183AAA-1069-11D7-AA41-000740323A8D}.type",
      "source": "キハ183-0番台+スハネフ14",
      "translation": "Kiha 183-0 Series + Suhanefu 14"
    },
    {
      "key": "contribution.{DC183AAA-1069-11D7-AA41-000740323A8D}.description",
      "source": "夜行特急オホーツク9,10号にはキハ183系気動車に挟まれて、スハネフ14形寝台客車が連結されている。",
      "translation": "Suhanev 14 Series sleeper coaches are coupled between Kiha 183 Series diesel railcars on the overnight Limited Express Okhotsk Nos. 9 and 10."
    },
    {
      "key": "contribution.{15ED3147-F3B2-4C96-A620-54CD0A6EF500}.name",
      "source": "利尻",
      "translation": "Rishiri"
    },
    {
      "key": "contribution.{15ED3147-F3B2-4C96-A620-54CD0A6EF500}.company",
      "source": "JR北海道",
      "translation": "JR Hokkaido"
    },
    {
      "key": "contribution.{15ED3147-F3B2-4C96-A620-54CD0A6EF500}.type",
      "source": "キハ400形+スハネフ14",
      "translation": "Kiha 400 Series + Suhanefu 14"
    },
    {
      "key": "contribution.{15ED3147-F3B2-4C96-A620-54CD0A6EF500}.description",
      "source": "宗谷線の急行にキハ400形が使用される際、夜行列車の「利尻」にはスハネフ14形寝台客車が編成中間に連結された。",
      "translation": "When Kiha 400 Series was used for express services on the Sōya Line, a Suhanev 14 Series sleeper coach was coupled in the middle of the 'Rishiri' night train formation."
    },
    {
      "key": "contribution.{ADF87135-9F9C-058A-9B45-04F846A0479D}.company",
      "source": "旧日本国有鉄道",
      "translation": "former JNR"
    },
    {
      "key": "contribution.{ADF87135-9F9C-058A-9B45-04F846A0479D}.type",
      "source": "キハ58系",
      "translation": "Kiha 58 Series"
    },
    {
      "key": "contribution.{ADF87135-9F9C-058A-9B45-04F846A0479D}.description",
      "source": "国鉄の急行型気動車。大量に生産されローカル輸送にも広く活躍した。全国の非電化区間で見る事が出来たが、老朽化で数が減っている。",
      "translation": "JNR express diesel railcar. Produced in large quantities, it was widely active in local transport. It could be seen on non-electrified sections nationwide, but its numbers are decreasing due to aging."
    },
    {
      "key": "contribution.{ADF87135-9F9C-065A-9B45-04F846A0479D}.company",
      "source": "旧日本国有鉄道",
      "translation": "former JNR"
    },
    {
      "key": "contribution.{ADF87135-9F9C-065A-9B45-04F846A0479D}.type",
      "source": "キハ58系+キハ65系",
      "translation": "Kiha 58 Series + Kiha 65 Series"
    },
    {
      "key": "contribution.{ADF87135-9F9C-065A-9B45-04F846A0479D}.description",
      "source": "キハ65形はキハ181系の流れをくむ大出力エンジン１台と冷房用の電源を搭載している。キハ58系の編成にこの車両を組み込むことで山岳路線など大出力を必要とする列車の冷房化が行われた。",
      "translation": "The Kiha 65 is equipped with a high-output engine and a power source for air conditioning, derived from the Kiha 181 series. By incorporating this car into Kiha 58 series formations, air conditioning was introduced for trains requiring high output, such as on mountain routes."
    }
  ]
