  "texts": [
    {
      "key": "plugin.title",
      "source": "京津セット",
      "translation": ""
    },
    {
      "key": "contribution.{nyaganyaga-k80}.company",
      "source": "京阪電鉄",
      "translation": ""
    },
    {
      "key": "contribution.{nyaganyaga-k80}.type",
      "source": "80形",
      "translation": ""
    },
    {
      "key": "contribution.{nyaganyaga-k80}.description",
      "source": "京阪三条～浜大津間を結ぶ併用軌道あり、峠越えありの日本でもここだけしか見られなかった路線が京津線です。その京津線を走っていたのが80形と呼ばれる可愛い電車です。ヨーロピアンスタイルの車両に高出力モーターを装備し、京津線の顔として普通運用をしていました。",
      "translation": ""
    },
    {
      "key": "contribution.{nyaganyaga-k800}.company",
      "source": "京阪電鉄",
      "translation": ""
    },
    {
      "key": "contribution.{nyaganyaga-k800}.type",
      "source": "800系",
      "translation": ""
    },
    {
      "key": "contribution.{nyaganyaga-k800}.description",
      "source": "1997年、京津線三条～御陵間が廃止され、代わって地下鉄東西線への乗入れの為に製作された京津線初の大型4連車。IGBTインバータ(これも京津線初)や先頭固定クロス、中間ロングと変則的なシートを採用、また車体色も京阪標準色と異なった色を採用している。上栄町～浜大津間の併用軌道を大型4連車が走るのは凄い迫力です。",
      "translation": ""
    }
  ]
}
