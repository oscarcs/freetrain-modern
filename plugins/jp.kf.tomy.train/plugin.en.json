    {
      "key": "contribution.{freetrain-tomy-20050530-jnr415}.company",
      "source": "旧日本国有鉄道",
      "translation": ""
    },
    {
      "key": "contribution.{freetrain-tomy-20050530-jnr415}.type",
      "source": "415系",
      "translation": ""
    },
    {
      "key": "contribution.{freetrain-tomy-20050530-jnr415}.description",
      "source": "1971年に登場した交流50/60Hz両用の整流器を搭載し、かつ直流との切替えができる｢三電気方式｣の近郊形電車",
      "translation": ""
    },
    {
      "key": "contribution.{freetrain-tomy-train-20050531-jre251}.name",
      "source": "スーパービュー踊り子(新)",
      "translation": ""
    },
    {
      "key": "contribution.{freetrain-tomy-train-20050531-jre251}.company",
