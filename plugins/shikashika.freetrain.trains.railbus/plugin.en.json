      "translation": ""
    },
    {
      "key": "contribution.{FreeTrain-Shika-RailroadTrain-meitetu-kiha10-railbus}.type",
      "source": "キハ10",
      "translation": ""
    },
    {
      "key": "contribution.{FreeTrain-Shika-RailroadTrain-meitetu-kiha10-railbus}.description",
      "source": "八百津線と三河線用に1984(昭和59)年に富士重工で非冷房車が製造され、1985(昭和60)年に冷房車が製造されました。1995(平成7)年に全車廃車となっていますが、冷房車2両(キハ15･16)はくりはら田園鉄道に移籍されました。",
      "translation": ""
    }
  ]
