      "translation": ""
    },
    {
      "key": "contribution.{8B8C5CB2-T80-43a5-kansai-4528788BF74E}.type",
      "source": "80系電車",
      "translation": ""
    },
    {
      "key": "contribution.{8B8C5CB2-T80-43a5-kansai-4528788BF74E}.description",
      "source": "関西地方の80系はクリーム色とぶどう色に塗られて活躍しました。",
      "translation": ""
    },
    {
      "key": "contribution.{8B8C5CB2-T80-43a5-kansaiEX-4528788BF74E}.name",
      "source": "関西急電",
      "translation": ""
    },
    {
      "key": "contribution.{8B8C5CB2-T80-43a5-kansaiEX-4528788BF74E}.company",
