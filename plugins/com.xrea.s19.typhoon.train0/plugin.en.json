  "texts": [
    {
      "key": "plugin.title",
      "source": "車両セット　0号車",
      "translation": "Vehicle Set Car 0"
    },
    {
      "key": "contribution.{TYPHOON-JNR-k55-HENSEI-7567171D3CEF}.name",
      "source": "急行色",
      "translation": "Express color"
    },
    {
      "key": "contribution.{TYPHOON-JNR-k55-HENSEI-7567171D3CEF}.company",
      "source": "旧日本国有鉄道",
      "translation": "former JNR"
    },
    {
      "key": "contribution.{TYPHOON-JNR-k55-HENSEI-7567171D3CEF}.type",
      "source": "キハ55系",
      "translation": "Kiha 55 Series"
    },
    {
      "key": "contribution.{TYPHOON-JNR-k55-HENSEI-7567171D3CEF}.description",
      "source": "8両まで編成可",
      "translation": "Can be formed with up to 8 cars."
    },
    {
      "key": "contribution.{TYPHOON-NANKAI-k5501-HENSEI-7567171D3CEF}.company",
      "source": "南海電鉄",
      "translation": "Nankai Electric Railway"
    },
    {
      "key": "contribution.{TYPHOON-NANKAI-k5501-HENSEI-7567171D3CEF}.type",
      "source": "キハ5501系",
      "translation": "Kiha 5501 Series"
    },
    {
      "key": "contribution.{TYPHOON-NANKAI-k5501-HENSEI-7567171D3CEF}.description",
      "source": "南海電気鉄道が国鉄紀勢本線への乗り入れの為、国鉄キハ55を基に昭和34年に製造した気動車。準急きのくにとして走り、後に急行に格上げされました。昭和60年の国鉄ダイヤ改正で廃止となりキハ5501も引退しました。\n（8両まで編成可）",
      "translation": "A diesel railcar manufactured by Nankai Electric Railway in 1959 (Showa 34) based on JNR Kiha 55 for through-service to the JNR Kisei Main Line. It ran as the Semi-Express Kinokuni and was later upgraded to an express. It was abolished with the JNR timetable revision in 1985 (Showa 60), and Kiha 5501 was also retired. (Can form up to 8 cars)"
    },
    {
      "key": "contribution.{TYPHOON-NANKAI-KINOKUNI-HENSEI-7567171D3CEF}.name",
      "source": "きのくに",
      "translation": "Kinokuni"
    },
    {
      "key": "contribution.{TYPHOON-NANKAI-KINOKUNI-HENSEI-7567171D3CEF}.company",
      "source": "南海電鉄",
      "translation": "Nankai Electric Railway"
    },
    {
      "key": "contribution.{TYPHOON-NANKAI-KINOKUNI-HENSEI-7567171D3CEF}.type",
      "source": "キハ5501系+キハ58系",
      "translation": "Kiha 5501 Series + Kiha 58 Series"
    },
    {
      "key": "contribution.{TYPHOON-NANKAI-KINOKUNI-HENSEI-7567171D3CEF}.description",
      "source": "（8両のみ編成可）",
      "translation": "(Formations of 8 cars only)"
    }
  ]
}
