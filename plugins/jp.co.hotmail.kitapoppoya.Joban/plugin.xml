<price>35000000</price>
<amenity>100</amenity>
<speed>medium</speed>
 <class name="freetrain.contributions.train.ParamTrainImpl"/>
 <composition>
   <head carRef="{69ADC1FD-A7A8-4963-B63C-C66-207900-A}"/>
   <body carRef="{69ADC1FD-A7A8-4963-B63C-C66-207900-C}"/>
   <tail carRef="{69ADC1FD-A7A8-4963-B63C-C66-207900-B}"/>
 </composition>
</contribution>
 <contribution type="train" id="{69ADC1FD-A7A8-4963-B63C-C6-2091000-W}">
<company>JR東日本</company>
<type>209系1000番台</type>
<name>常磐緩行線</name>
<author>北の汽車屋</author>
<description>輸送力増強を目的にして二編成が導入された、常磐緩行線の新顔。E231導入後ではあったものの209系をベースとしている。
</description>
<fare>400</fare>
<price>25000000</price>
<amenity>100</amenity>
<speed>medium</speed>
 <class name="freetrain.contributions.train.ParamTrainImpl"/>
 <composition>
   <head carRef="{69ADC1FD-A7A8-4963-B63C-C6-2091000-A}"/>
   <body carRef="{69ADC1FD-A7A8-4963-B63C-C6-2091000-C}"/>
   <tail carRef="{69ADC1FD-A7A8-4963-B63C-C6-2091000-B}"/>
 </composition>
</contribution>
 <contribution type="train" id="{69ADC1FD-A7A8-4963-B63C-C6685-E531-W}">
<company>JR東日本</company>
<type>E531系</type>
<name>常磐快速</name>
<author>北の汽車屋</author>
<description>2005年から導入が開始される、常磐線の新顔。E231系の近郊型をベースとし、交直流区間直通・130km/h走行を可能にする。
</description>
<fare>500</fare>
<price>38000000</price>
<amenity>100</amenity>
<triprange>middle</triprange>
<speed>medium</speed>
 <class name="freetrain.contributions.train.ParamTrainImpl"/>
 <composition>
   <head carRef="{69ADC1FD-A7A8-4963-B63C-C6685-E531-A}"/>
   <body carRef="{69ADC1FD-A7A8-4963-B63C-C6685-E531-C}"/>
   <tail carRef="{69ADC1FD-A7A8-4963-B63C-C6685-E531-B}"/>
 </composition>
</contribution>
<contribution type="train" id="{669D5BDE-23F1-43BD-AC36-B-E531G}">
<company>JR東日本</company>
<type>E531系(グリーン車組み込み編成)</type>
<name>常磐快速</name>
<author>北の汽車屋</author>
<description>TXの開業に対抗し、常磐快速のE531系にもWデッカーのグリーン車組み込みが始まった。こちらは忠実の編成に従っています。
</description>
<fare>550</fare>
<triprange>middle</triprange>
<price>40000000</price>
<amenity>110</amenity>
<speed>medium</speed>
<class name="freetrain.contributions.train.PatternTrainImpl"/>
<config>
<car char="A" ref="{669D5BDE-23F1-43BD-AC36-E531G-A}"/>
<car char="C" ref="{669D5BDE-23F1-43BD-AC36-E531G-C}"/>
<car char="B" ref="{669D5BDE-23F1-43BD-AC36-E531G-B}"/> 
<car char="G" ref="{669D5BDE-23F1-43BD-AC36-E531G-G}"/> 
<composition>ACCCB</composition>
<composition>ACCGGCCCCB</composition>
<composition>ACCCBACCGGCCCCB</composition>
</config>
</contribution>
