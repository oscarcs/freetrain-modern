{
  "language": "en",
  "plugin": "shikashika.freetrain.trains.railbus",
  "sourceManifest": "plugin.xml",
  "texts": [
    {
      "key": "plugin.title",
      "source": "車輌(気動車:レールバス)",
      "translation": ""
    },
    {
      "key": "contribution.{FreeTrain-Shika-RailroadTrain-kiha01-railbus}.name",
      "source": "レールバス",
      "translation": ""
    },
    {
      "key": "contribution.{FreeTrain-Shika-RailroadTrain-kiha01-railbus}.company",
      "source": "旧日本国有鉄道",
      "translation": ""
    },
    {
      "key": "contribution.{FreeTrain-Shika-RailroadTrain-kiha01-railbus}.type",
      "source": "キハ01",
      "translation": ""
    },
    {
      "key": "contribution.{FreeTrain-Shika-RailroadTrain-kiha01-railbus}.description",
      "source": "レールバスと呼ばれた小型ディーゼルカーです。1954年から12両製造されています。製造当初はキハ10000～11でしたが、1957年に旧キハ10000～03がキハ01の1～4に、旧キハ10004～11がキハ01の51～58に改番されています。",
      "translation": ""
    },
    {
      "key": "contribution.{FreeTrain-Shika-RailroadTrain-kiyuni01-railbus}.name",
      "source": "レールバス",
      "translation": ""
    },
    {
      "key": "contribution.{FreeTrain-Shika-RailroadTrain-kiyuni01-railbus}.company",
      "source": "旧日本国有鉄道",
      "translation": ""
    },
    {
      "key": "contribution.{FreeTrain-Shika-RailroadTrain-kiyuni01-railbus}.type",
      "source": "キユニ01",
      "translation": ""
    },
    {
      "key": "contribution.{FreeTrain-Shika-RailroadTrain-kiyuni01-railbus}.description",
      "source": "1952年にキハ01-55の室内のみを改造しキユニ01-1としたもので、1両のみ製造されました。山陰本線と三江北線で使用され、昭和42年に廃車されています。",
      "translation": ""
    },
    {
      "key": "contribution.{FreeTrain-Shika-RailroadTrain-kiha02-railbus}.name",
      "source": "レールバス",
      "translation": ""
    },
    {
      "key": "contribution.{FreeTrain-Shika-RailroadTrain-kiha02-railbus}.company",
      "source": "旧日本国有鉄道",
      "translation": ""
    },
    {
      "key": "contribution.{FreeTrain-Shika-RailroadTrain-kiha02-railbus}.type",
      "source": "キハ02",
      "translation": ""
    },
    {
      "key": "contribution.{FreeTrain-Shika-RailroadTrain-kiha02-railbus}.description",
      "source": "レールバスと呼ばれた小型ディーゼルカーです。キハ02系は17両製造されました。製造当初はキハ10012～28でしたが、1957年にキハ02 1～17に改番されています。",
      "translation": ""
    },
    {
      "key": "contribution.{FreeTrain-Shika-RailroadTrain-kiha03-railbus}.name",
      "source": "レールバス",
      "translation": ""
    },
    {
      "key": "contribution.{FreeTrain-Shika-RailroadTrain-kiha03-railbus}.company",
      "source": "旧日本国有鉄道",
      "translation": ""
    },
    {
      "key": "contribution.{FreeTrain-Shika-RailroadTrain-kiha03-railbus}.type",
      "source": "キハ03",
      "translation": ""
    },
    {
      "key": "contribution.{FreeTrain-Shika-RailroadTrain-kiha03-railbus}.description",
      "source": "1956年に東急車輌でキハ02を基本に北海道向けとして製造された極寒仕様のレールバスです。客窓は二重窓になり、暖房装置が強化が図られています。製造当初はキハ10200～10219でしたが、1957年にキハ03 1～20に改番されています。1966年までに全車廃車となっています。",
      "translation": ""
    },
    {
      "key": "contribution.{FreeTrain-Shika-RailroadTrain-nanbu-kiha10-railbus}.name",
      "source": "レールバス",
      "translation": ""
    },
    {
      "key": "contribution.{FreeTrain-Shika-RailroadTrain-nanbu-kiha10-railbus}.company",
      "source": "南部縦貫鉄道",
      "translation": ""
    },
    {
      "key": "contribution.{FreeTrain-Shika-RailroadTrain-nanbu-kiha10-railbus}.type",
      "source": "キハ10",
      "translation": ""
    },
    {
      "key": "contribution.{FreeTrain-Shika-RailroadTrain-nanbu-kiha10-railbus}.description",
      "source": "1962(昭和37)年10月20日の南部縦貫鉄道の開業に合わせて富士重工で製造されました。1996年にエバーグリーン賞受賞。なお南部縦貫鉄道は1997(平成9)年5月5日に営業休止となり、後の2002(平成14)年8月1日をもって鉄道事業廃止となっています。",
      "translation": ""
    },
    {
      "key": "contribution.{FreeTrain-Shika-RailroadTrain-tarumi-haimo180-railbus}.name",
      "source": "レールバス",
      "translation": ""
    },
    {
      "key": "contribution.{FreeTrain-Shika-RailroadTrain-tarumi-haimo180-railbus}.company",
      "source": "樽見鉄道",
      "translation": ""
    },
    {
      "key": "contribution.{FreeTrain-Shika-RailroadTrain-tarumi-haimo180-railbus}.type",
      "source": "ハイモ180",
      "translation": ""
    },
    {
      "key": "contribution.{FreeTrain-Shika-RailroadTrain-tarumi-haimo180-railbus}.description",
      "source": "富士重工製造のLE-Car(ライトエコノミー・ディーゼルカー)のレールバスです。クロスシートとロングシートの3両ありましたが、クロスシートだった1両は和歌山県の有田鉄道に譲渡されました。",
      "translation": ""
    },
    {
      "key": "contribution.{FreeTrain-Shika-RailroadTrain-arita-haimo180-railbus}.name",
      "source": "レールバス",
      "translation": ""
    },
    {
      "key": "contribution.{FreeTrain-Shika-RailroadTrain-arita-haimo180-railbus}.company",
      "source": "有田鉄道",
      "translation": ""
    },
    {
      "key": "contribution.{FreeTrain-Shika-RailroadTrain-arita-haimo180-railbus}.type",
      "source": "ハイモ180",
      "translation": ""
    },
    {
      "key": "contribution.{FreeTrain-Shika-RailroadTrain-arita-haimo180-railbus}.description",
      "source": "富士重工製造のLE-Car(ライトエコノミー・ディーゼルカー)のレールバスです。樽見鉄道より譲渡されたもので、クロスシート34席定員70名です。",
      "translation": ""
    },
    {
      "key": "contribution.{FreeTrain-Shika-RailroadTrain-miki-miki180-railbus}.name",
