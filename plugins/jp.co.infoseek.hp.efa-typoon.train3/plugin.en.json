    },
    {
      "key": "contribution.{57644AE6-7FFA-E231-8FE0-7567171D3CEF}.description",
      "source": "地下鉄東西線に直通する301系、103系1200番台の置き換えとして用として投入された車両。",
      "translation": "A train introduced to replace the 301 Series and 103 Series 1200 sub-series, which operate through services on the Tozai Subway Line."
    },
    {
      "key": "contribution.{57644AE6-7FFA-K283-8FE0-7567171D3CEF}.name",
      "source": "スーパーおおぞら、スーパーとかち など",
      "translation": "Super Ozora, Super Tokachi, etc."
    },
    {
      "key": "contribution.{57644AE6-7FFA-K283-8FE0-7567171D3CEF}.company",
      "source": "JR北海道",
      "translation": "JR Hokkaido"
    },
    {
      "key": "contribution.{57644AE6-7FFA-K283-8FE0-7567171D3CEF}.type",
      "source": "キハ283系",
      "translation": "Kiha 283 Series"
    },
    {
      "key": "contribution.{57644AE6-7FFA-K283-8FE0-7567171D3CEF}.description",
      "source": "石勝線、根室本線を高速化するために開発された。キハ281系をベースとした振り子車である。",
      "translation": "Developed to speed up the Sekishō Line and Nemuro Main Line. It is a tilting train based on the Kiha 281 Series."
    },
    {
      "key": "contribution.{57644AE6-7FFA-K261-8FE0-7567171D3CEF}.name",
      "source": "スーパー宗谷 など",
      "translation": "Super Soya, etc."
    },
    {
      "key": "contribution.{57644AE6-7FFA-K261-8FE0-7567171D3CEF}.company",
      "source": "JR北海道",
      "translation": "JR Hokkaido"
    },
    {
      "key": "contribution.{57644AE6-7FFA-K261-8FE0-7567171D3CEF}.type",
      "source": "キハ261系",
      "translation": "Kiha 261 Series"
    },
    {
      "key": "contribution.{57644AE6-7FFA-K261-8FE0-7567171D3CEF}.description",
      "source": "宗谷本線旭川～名寄間を高速化するために開発された。外見はキハ281系、キハ283系によく似ている。",
      "translation": "Developed to increase speed on the Sōya Main Line between Asahikawa and Nayoro. Its appearance is very similar to the Kiha 281 Series and Kiha 283 Series."
    },
    {
      "key": "contribution.{cyber-express-1703d-040105-ec789}.name",
