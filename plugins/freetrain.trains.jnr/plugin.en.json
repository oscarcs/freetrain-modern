      "translation": ""
    },
    {
      "key": "contribution.{3991CE43-T101-4923-JNR-9DA7803AW}.type",
      "source": "101系",
      "translation": ""
    },
    {
      "key": "contribution.{3991CE43-T101-4923-JNR-9DA7803AW}.description",
      "source": "老朽化した72系電車を置き換えるために作られたのが101系。\n\t\t\t当初はオールM車であったが、電力設備の能力を超えたため最終的には6M4Tに変更された。",
      "translation": ""
    },
    {
      "key": "contribution.{3991CE43-T101-4923-JRE-9DA7803A}.name",
      "source": "南武支線",
      "translation": ""
    },
    {
      "key": "contribution.{3991CE43-T101-4923-JRE-9DA7803A}.company",
      "source": "JR東日本",
      "translation": ""
    },
    {
      "key": "contribution.{3991CE43-T101-4923-JRE-9DA7803A}.type",
      "source": "101系",
      "translation": ""
    },
    {
      "key": "contribution.{3991CE43-T101-4923-JRE-9DA7803A}.description",
      "source": "南武の浜川崎支線で使われたいた塗装です。\n\t\t\t浜川崎支線は最後の101系の活躍の場であったが、2003年12月を最後に205系に置き換われ引退しました。",
      "translation": ""
    }
