<company>JR東日本</company>
<type>203系</type>
<name>常磐緩行線</name>
<author>北の汽車屋</author>
<description>現在の常磐緩行線の主役。201系がベース。100番代以降は205系に準じた台車を履いている。
</description>
<fare>400</fare>
<price>35000000</price>
<amenity>100</amenity>
<speed>medium</speed>
 <class name="freetrain.contributions.train.ParamTrainImpl"/>
 <composition>
   <head carRef="{69ADC1FD-A7A8-4963-B63C-C66852-203-A}"/>
   <body carRef="{69ADC1FD-A7A8-4963-B63C-C66852-203-C}"/>
   <tail carRef="{69ADC1FD-A7A8-4963-B63C-C66852-203-B}"/>
 </composition>
</contribution>
