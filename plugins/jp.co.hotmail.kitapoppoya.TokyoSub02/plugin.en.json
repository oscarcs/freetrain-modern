      "translation": "Asakusa Line"
    },
    {
      "key": "contribution.{57644AE6-7FFA-A231-8FE0-75-TOEI5300}.company",
      "source": "東京都交通局",
      "translation": "Tokyo Metropolitan Bureau of Transportation"
    },
    {
      "key": "contribution.{57644AE6-7FFA-A231-8FE0-75-TOEI5300}.type",
